DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=camera_rental
DB_USER=postgres
DB_PASSWORD=YOUR_PG_PASSWORD

# Required: session secret for signing session cookies.
SESSION_SECRET=replace-with-a-long-random-string

# Only enable in development/test.
ENABLE_MOCK_GOOGLE_LOGIN=false

# Password hashing cost.
PASSWORD_HASH_ROUNDS=10

# Initial admin seed (required on first run if no admin exists)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@camera.com
ADMIN_PASSWORD=change-this-strong-password

# Schema sync mode:
# - false (recommended): sync without altering columns
# - true (dev only): allow Sequelize to alter schema automatically
DB_SYNC_ALTER=true
