DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=camera_rental
DB_USER=postgres
DB_PASSWORD=YOUR_PASSWORD ## แก้ รหัส pgadminตรงนี้

# Required: used to sign session cookies
SESSION_SECRET=replace-with-a-long-random-string

# Optional in local dev. Production should always use secure cookies.
SESSION_COOKIE_SECURE=false

# Initial admin seed (required on first run if no admin exists)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@camera.com
ADMIN_PASSWORD=change-this-strong-password
