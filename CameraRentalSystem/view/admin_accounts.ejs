<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Accounts</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#f8f9fa] min-h-screen font-sans text-slate-800">
    <nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex items-center gap-3">
                    <div class="bg-slate-900 p-2 rounded-lg">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                    </div>
                    <div>
                        <h1 class="text-xl font-bold text-slate-900 tracking-tight">Manage Accounts</h1>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <a href="/admin" class="text-indigo-600 hover:text-indigo-800 text-sm font-semibold transition">Back to Dashboard</a>
                    <span class="w-px h-4 bg-gray-300"></span>
                    <a href="/main" class="text-slate-600 hover:text-slate-900 text-sm font-medium transition">Main</a>
                    <span class="w-px h-4 bg-gray-300"></span>
                    <a href="/browse" class="text-slate-600 hover:text-slate-900 text-sm font-medium transition">Storefront</a>
                </div>
            </div>
        </div>
    </nav>

  <main class="max-w-6xl mx-auto p-6 mt-6">
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-slate-900 tracking-tight">Admin Account Management</h1>
      <p class="text-sm text-slate-500 mt-1">Manage user roles and create new admin users</p>
    </div>

    <% if (error) { %>
      <div class="mb-6 p-4 rounded-xl border border-red-200 bg-red-50 text-red-700 font-medium text-sm shadow-sm"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="mb-6 p-4 rounded-xl border border-emerald-200 bg-emerald-50 text-emerald-700 font-medium text-sm shadow-sm"><%= success %></div>
    <% } %>

    <section class="bg-white rounded-2xl border border-gray-100 shadow-[0_2px_8px_-3px_rgba(0,0,0,0.05)] p-6 mb-8">
      <h2 class="text-lg font-bold text-slate-800 tracking-tight mb-5">Create New Admin</h2>
      <form action="/admin/accounts/create-admin" method="POST" class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="text" name="username" placeholder="Username" class="border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all" required>
        <input type="email" name="email" placeholder="Email" class="border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all" required>
        <input type="password" name="password" placeholder="Password (min 8 chars)" class="border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all" required>
        <button type="submit" class="bg-indigo-600 text-white rounded-lg px-4 py-2.5 font-medium text-sm hover:bg-indigo-700 hover:shadow-md transition-all">Create Admin</button>
      </form>
    </section>

    <section class="bg-white rounded-2xl border border-gray-100 shadow-[0_2px_8px_-3px_rgba(0,0,0,0.05)] overflow-hidden">
      <div class="p-6 border-b border-gray-50 flex items-center justify-between">
        <h2 class="text-lg font-bold text-slate-800 tracking-tight">All Users</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full text-sm divide-y divide-gray-100">
          <thead class="bg-slate-50/50">
            <tr>
              <th class="text-left px-6 py-4 font-semibold text-slate-500 uppercase tracking-wider text-xs">Username</th>
              <th class="text-left px-6 py-4 font-semibold text-slate-500 uppercase tracking-wider text-xs">Email</th>
              <th class="text-left px-6 py-4 font-semibold text-slate-500 uppercase tracking-wider text-xs">Current Role</th>
              <th class="text-left px-6 py-4 font-semibold text-slate-500 uppercase tracking-wider text-xs">Change Role</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50 bg-white">
            <% users.forEach((item) => { %>
              <tr class="hover:bg-slate-50/50 transition-colors">
                <td class="px-6 py-4 whitespace-nowrap font-medium text-slate-900"><%= item.username %></td>
                <td class="px-6 py-4 whitespace-nowrap text-slate-500"><%= item.email %></td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="px-2.5 py-1 rounded-md text-xs font-semibold <%= item.role === 'admin' ? 'bg-indigo-50 text-indigo-700' : 'bg-gray-100 text-gray-700' %>">
                    <%= item.role %>
                  </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <form action="/admin/accounts/role" method="POST" class="flex items-center gap-3">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <input type="hidden" name="username" value="<%= item.username %>">
                    <select name="role" class="border border-gray-200 rounded-md px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500 bg-white">
                      <option value="user" <%= item.role === 'user' ? 'selected' : '' %>>user</option>
                      <option value="admin" <%= item.role === 'admin' ? 'selected' : '' %>>admin</option>
                    </select>
                    <button type="submit" class="bg-slate-900 text-white rounded-md px-4 py-1.5 text-xs font-semibold hover:bg-slate-800 transition">Save</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  </main>
</body>
</html>
