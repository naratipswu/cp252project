<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Accounts</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen">
  <main class="max-w-6xl mx-auto p-6">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-2xl font-bold text-gray-900">Admin Account Management</h1>
      <div class="flex items-center gap-2">
        <a href="/main" class="px-4 py-2 bg-emerald-600 text-white rounded hover:bg-emerald-500 transition">Go to Main</a>
        <a href="/browse" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-500 transition">Go to Browse</a>
        <a href="/admin" class="px-4 py-2 bg-gray-900 text-white rounded hover:bg-gray-700 transition">Back to Admin</a>
      </div>
    </div>

    <% if (error) { %>
      <div class="mb-4 p-3 rounded border border-red-300 bg-red-50 text-red-700"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="mb-4 p-3 rounded border border-green-300 bg-green-50 text-green-700"><%= success %></div>
    <% } %>

    <section class="bg-white rounded-lg border shadow p-6 mb-6">
      <h2 class="text-lg font-semibold mb-4">Create New Admin</h2>
      <form action="/admin/accounts/create-admin" method="POST" class="grid grid-cols-1 md:grid-cols-4 gap-3">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="text" name="username" placeholder="username" class="border rounded px-3 py-2" required>
        <input type="email" name="email" placeholder="email" class="border rounded px-3 py-2" required>
        <input type="password" name="password" placeholder="password (min 8 chars)" class="border rounded px-3 py-2" required>
        <button type="submit" class="bg-indigo-600 text-white rounded px-4 py-2 hover:bg-indigo-500 transition">Create Admin</button>
      </form>
    </section>

    <section class="bg-white rounded-lg border shadow p-6">
      <h2 class="text-lg font-semibold mb-4">All Users</h2>
      <div class="overflow-x-auto">
        <table class="min-w-full border border-gray-200 text-sm">
          <thead class="bg-gray-50">
            <tr>
              <th class="text-left px-4 py-2 border-b">Username</th>
              <th class="text-left px-4 py-2 border-b">Email</th>
              <th class="text-left px-4 py-2 border-b">Current Role</th>
              <th class="text-left px-4 py-2 border-b">Change Role</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach((item) => { %>
              <tr class="odd:bg-white even:bg-gray-50">
                <td class="px-4 py-2 border-b"><%= item.username %></td>
                <td class="px-4 py-2 border-b"><%= item.email %></td>
                <td class="px-4 py-2 border-b">
                  <span class="<%= item.role === 'admin' ? 'text-indigo-700 font-semibold' : 'text-gray-700' %>">
                    <%= item.role %>
                  </span>
                </td>
                <td class="px-4 py-2 border-b">
                  <form action="/admin/accounts/role" method="POST" class="flex items-center gap-2">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <input type="hidden" name="username" value="<%= item.username %>">
                    <select name="role" class="border rounded px-2 py-1">
                      <option value="user" <%= item.role === 'user' ? 'selected' : '' %>>user</option>
                      <option value="admin" <%= item.role === 'admin' ? 'selected' : '' %>>admin</option>
                    </select>
                    <button type="submit" class="bg-gray-900 text-white rounded px-3 py-1 hover:bg-gray-700 transition">Save</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  </main>
</body>
</html>
