<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us - Camera Rental</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@400;700;900&display=swap"
        rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        .font-serif-elegant {
            font-family: 'Playfair Display', serif;
        }

        .bg-brand-brown {
            background-color: #1a150d;
        }

        .text-brand-yellow {
            color: #d69e2e;
        }

        .bg-brand-yellow {
            background-color: #d69e2e;
        }

        .border-brand-yellow {
            border-color: #d69e2e;
        }
        
        .bg-pattern {
            background-image: radial-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px);
            background-size: 40px 40px;
        }
    </style>
</head>

<body class="bg-brand-brown text-white min-h-screen relative flex flex-col bg-pattern">

    <!-- Navbar -->
    <nav class="flex h-16 w-full shrink-0 border-b border-white/10 relative z-10 bg-brand-brown">
        <!-- Logo Area -->
        <a href="/" class="bg-brand-yellow text-black font-black text-lg md:text-xl flex items-center justify-center px-6 md:px-10 tracking-wider hover:bg-yellow-500 transition">
            CAMERA TYPE
        </a>

        <!-- Navigation Links -->
        <div class="flex-1 bg-[#222] flex items-center justify-start px-8 gap-8 hidden md:flex">
            <a href="/browse?type=digital" class="text-white font-bold tracking-wider hover:text-brand-yellow transition">DIGITAL</a>
            <a href="/browse?type=film" class="text-white font-bold tracking-wider hover:text-brand-yellow transition">FILM</a>
            <a href="#" class="text-white font-bold tracking-wider hover:text-brand-yellow transition">PHOTO</a>
            <a href="/process" class="text-white font-bold tracking-wider hover:text-brand-yellow transition">PROCESS</a>
            <a href="/contact" class="text-brand-yellow font-bold tracking-wider transition">CONTACT</a>
        </div>

        <!-- Icons Area -->
        <div class="bg-white text-black flex items-center justify-center px-6 gap-6 ml-auto md:ml-0">
            <a href="<%= user ? '/profile' : '/signin' %>" class="hover:text-gray-600 transition" title="<%= user ? 'Profile' : 'Sign in' %>">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                </svg>
            </a>
            <a href="/cart" class="hover:text-gray-600 transition" title="Cart">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z">
                    </path>
                </svg>
            </a>
        </div>
    </nav>

    <!-- Content -->
    <main class="flex-1 flex flex-col items-center justify-center py-20 px-4 md:px-8 max-w-6xl mx-auto w-full relative z-10">
        
        <div class="text-center mb-16 md:mb-20">
            <h1 class="font-serif-elegant text-5xl md:text-7xl mb-4 text-white drop-shadow-lg tracking-wide">CONTACT US</h1>
            <div class="w-16 h-1 bg-brand-yellow mx-auto my-6"></div>
            <p class="font-serif-elegant text-lg md:text-2xl italic text-gray-400">ติดต่อเราเพื่อสอบถามข้อมูลเพิ่มเติม หรือเช่าอุปกรณ์จำนวนมาก</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 w-full max-w-5xl items-center">
            
            <!-- Left: Contact Details -->
            <div class="flex flex-col space-y-12">
                
                <div class="flex items-start gap-6 group">
                    <div class="w-16 h-16 shrink-0 rounded-full border border-gray-600 flex items-center justify-center text-gray-400 group-hover:border-brand-yellow group-hover:text-brand-yellow transition duration-300">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    </div>
                    <div>
                        <h3 class="text-sm tracking-widest text-brand-yellow uppercase mb-1 font-bold">Address</h3>
                        <p class="text-gray-300 text-lg leading-relaxed">
                            123/45 ถนนเอกมัย แขวงคลองตันเหนือ<br>
                            เขตวัฒนา กรุงเทพมหานคร 10110
                        </p>
                    </div>
                </div>

                <div class="flex items-start gap-6 group">
                    <div class="w-16 h-16 shrink-0 rounded-full border border-gray-600 flex items-center justify-center text-gray-400 group-hover:border-brand-yellow group-hover:text-brand-yellow transition duration-300">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                    </div>
                    <div>
                        <h3 class="text-sm tracking-widest text-brand-yellow uppercase mb-1 font-bold">Email Inquiries</h3>
                        <p class="text-gray-300 text-lg leading-relaxed">
                            hello@cameratype.com<br>
                            support@cameratype.com
                        </p>
                    </div>
                </div>

                <div class="flex items-start gap-6 group">
                    <div class="w-16 h-16 shrink-0 rounded-full border border-gray-600 flex items-center justify-center text-gray-400 group-hover:border-brand-yellow group-hover:text-brand-yellow transition duration-300">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                    </div>
                    <div>
                        <h3 class="text-sm tracking-widest text-brand-yellow uppercase mb-1 font-bold">Phone</h3>
                        <p class="text-gray-300 text-lg leading-relaxed">
                            02-123-4567<br>
                            089-987-6543 (Hotline)
                        </p>
                    </div>
                </div>

            </div>

            <!-- Right: Beautiful Image Panel instead of a boring form -->
            <div class="relative w-full aspect-[4/5] lg:aspect-square flex justify-center items-center">
                <!-- Decorative Frame -->
                <div class="absolute inset-0 border border-brand-yellow/30 transform translate-x-4 translate-y-4"></div>
                
                <!-- Main Image Area -->
                <div class="absolute inset-0 bg-[#222] border border-white/10 overflow-hidden flex items-center justify-center flex-col p-8 text-center">
                    <div class="w-20 h-20 border border-gray-500 rounded-full flex items-center justify-center mb-6 text-gray-400 opacity-60">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path></svg>
                    </div>
                    <span class="text-gray-400 font-serif-elegant italic text-xl">Image Placeholder</span>
                    <span class="text-gray-500 text-sm mt-2">Replace with a beautiful interior photo of your studio</span>
                    
                    <!-- Real image layer (uncomment and replace src to use) -->
                    <!-- <img src="/uploads/images/studio.jpg" alt="Studio" class="absolute inset-0 w-full h-full object-cover z-10"> -->
                </div>
            </div>

        </div>

        <!-- Social Media / Maps link -->
        <div class="mt-24 text-center border-t border-white/10 w-full pt-12 flex flex-col items-center">
            <h3 class="font-serif-elegant italic text-gray-400 text-xl mb-6">Stay Connected</h3>
            <div class="flex gap-8">
                <a href="#" class="text-white hover:text-brand-yellow transition text-lg tracking-widest uppercase font-bold text-sm">Instagram</a>
                <a href="#" class="text-white hover:text-brand-yellow transition text-lg tracking-widest uppercase font-bold text-sm">Facebook</a>
                <a href="#" class="text-white hover:text-brand-yellow transition text-lg tracking-widest uppercase font-bold text-sm">Line Official</a>
            </div>
        </div>

    </main>

</body>
</html>
