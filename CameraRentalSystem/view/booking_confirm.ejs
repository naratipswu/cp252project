<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Confirm Booking | CAMERA RENTAL</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'brand-yellow': '#d69e2e',
                        'brand-brown': '#171717',
                        'brand-gray': '#222222',
                    },
                    fontFamily: {
                        'serif-elegant': ['"Playfair Display"', 'serif'],
                        'sans-modern': ['Inter', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        .glass-card {
            background: rgba(34, 34, 34, 0.6);
            backdrop-filter: blur(12px);
            border: 1px border rgba(255, 255, 255, 0.1);
        }
        .text-glow {
            text-shadow: 0 0 15px rgba(214, 158, 46, 0.3);
        }
    </style>
</head>
<body class="bg-brand-brown text-white font-sans-modern min-h-screen flex flex-col">

    <!-- Header / Navbar -->
    <nav class="flex h-16 w-full border-b border-white/5 sticky top-0 z-50 bg-brand-brown/80 backdrop-blur-md">
        <a href="/welcome" class="bg-brand-yellow text-black font-black text-xl flex items-center justify-center px-10 tracking-wider hover:bg-yellow-500 transition duration-300">
            CAMERA RENTAL
        </a>
        <div class="flex-1 flex items-center justify-end px-8 gap-6">
            <a href="/browse" class="text-sm font-semibold hover:text-brand-yellow transition">CANCEL & EXIT</a>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-1 flex items-center justify-center p-6 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-brand-gray/50 via-brand-brown to-brand-brown">
        <div class="w-full max-w-2xl glass-card rounded-3xl p-8 md:p-12 shadow-2xl relative overflow-hidden">
            <!-- Decorative Accent -->
            <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-brand-yellow to-transparent opacity-50"></div>

            <header class="mb-10 text-center">
                <h1 class="font-serif-elegant text-4xl md:text-5xl font-black mb-4 tracking-tight">Confirm Booking</h1>
                <p class="text-gray-400 font-light tracking-wide uppercase text-xs">Step 1 of 2: Review your order details</p>
            </header>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-10">
                <div class="bg-white/5 rounded-2xl p-6 border border-white/5">
                    <p class="text-[10px] text-brand-yellow font-bold uppercase tracking-widest mb-1">Booking ID</p>
                    <p class="text-xl font-semibold tracking-tight">#<%= booking.id %></p>
                </div>
                <div class="bg-white/5 rounded-2xl p-6 border border-white/5">
                    <p class="text-[10px] text-brand-yellow font-bold uppercase tracking-widest mb-1">Equipment</p>
                    <p class="text-xl font-semibold tracking-tight"><%= camera.brand %> <%= camera.model %></p>
                </div>
                <div class="bg-white/5 rounded-2xl p-6 border border-white/5">
                    <p class="text-[10px] text-brand-yellow font-bold uppercase tracking-widest mb-1">Rental Period</p>
                    <div class="flex items-center gap-3 text-sm font-medium">
                        <span><%= booking.startDate %></span>
                        <span class="text-brand-yellow">→</span>
                        <span><%= booking.endDate %></span>
                    </div>
                </div>
                <div class="bg-brand-yellow/10 rounded-2xl p-6 border border-brand-yellow/20">
                    <p class="text-[10px] text-brand-yellow font-bold uppercase tracking-widest mb-1">Total Payment</p>
                    <p class="text-3xl font-black text-brand-yellow text-glow"><%= booking.totalPrice %> <span class="text-sm font-normal">THB</span></p>
                </div>
            </div>

            <div class="flex flex-col md:flex-row items-center justify-between gap-6">
                <a href="/browse" class="text-gray-500 hover:text-white transition text-sm font-semibold tracking-widest uppercase">
                    &larr; Back to Browse
                </a>
                <form action="/booking/<%= booking.id %>/confirm" method="POST" class="w-full md:w-auto">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="w-full bg-brand-yellow text-black font-black py-4 px-10 rounded-full hover:bg-yellow-500 hover:scale-105 active:scale-95 transition duration-300 tracking-widest uppercase text-sm shadow-[0_10px_30px_rgba(214,158,46,0.3)]">
                        Confirm and Pay &rarr;
                    </button>
                </form>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-black/95 border-t border-white/10 py-16 px-6">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-12">
            <!-- Branding Area -->
            <div class="flex flex-col items-center md:items-start text-center md:text-left">
                <div class="bg-brand-yellow text-black font-black px-6 py-2 text-xl tracking-tighter mb-4 inline-block">
                    CAMERA RENTAL
                </div>
                <p class="text-gray-400 text-sm max-w-xs leading-relaxed">
                    Premium vintage camera rentals for your creative storytelling. Capture moments the old way with modern reliability.
                </p>
            </div>

            <!-- Group Credit Area -->
            <div class="flex flex-col items-center md:items-end text-center md:text-right">
                <h3 class="text-gray-500 font-bold text-xs uppercase tracking-[0.2em] mb-3">Developed By</h3>
                <div class="text-white font-black text-3xl md:text-4xl tracking-widest uppercase">
                    เกรซ<span class="text-brand-yellow">นาย</span>หรั่ง
                </div>
                <div class="mt-6 flex gap-6 text-gray-500 text-sm">
                    <span class="hover:text-brand-yellow transition cursor-default">CP252 Project</span>
                    <span class="text-gray-700">|</span>
                    <span>© 2026 Camera Rental</span>
                </div>
            </div>
        </div>
    </footer>

</body>
</html>
