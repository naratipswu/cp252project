<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Confirm Booking</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#f8f9fa] min-h-screen font-sans text-slate-800 flex items-center justify-center p-4">
    <div class="w-full max-w-2xl bg-white rounded-3xl shadow-[0_4px_24px_-8px_rgba(0,0,0,0.1)] border border-gray-100 overflow-hidden">
        <div class="h-2 w-full bg-indigo-600"></div>
        <div class="p-10">
            <h1 class="text-3xl font-bold tracking-tight text-slate-900 mb-2">Confirm Your Booking</h1>
            <p class="text-slate-500 mb-8">Please review details carefully before continuing to payment.</p>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
                <div class="bg-slate-50 border border-gray-100 rounded-xl p-5 shadow-sm">
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Booking ID</p>
                    <p class="font-bold text-slate-800">#<%= booking.id %></p>
                </div>
                <div class="bg-slate-50 border border-gray-100 rounded-xl p-5 shadow-sm">
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Camera Detail</p>
                    <p class="font-bold text-slate-800"><%= camera.brand %> <%= camera.model %></p>
                </div>
                <div class="bg-slate-50 border border-gray-100 rounded-xl p-5 shadow-sm">
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Start Date</p>
                    <p class="font-bold text-slate-800"><%= booking.startDate %></p>
                </div>
                <div class="bg-slate-50 border border-gray-100 rounded-xl p-5 shadow-sm">
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">End Date</p>
                    <p class="font-bold text-slate-800"><%= booking.endDate %></p>
                </div>
                
                <div class="bg-indigo-50 border border-indigo-100 rounded-xl p-6 sm:col-span-2 flex items-center justify-between shadow-sm">
                    <div>
                        <p class="text-xs font-bold text-indigo-400 uppercase tracking-widest mb-1">Total Pricing</p>
                        <p class="text-3xl font-black text-indigo-900"><%= Number(booking.totalPrice).toLocaleString() %> <span class="text-xl font-bold text-indigo-700">THB</span></p>
                    </div>
                    <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-indigo-500 shadow-sm">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                </div>
            </div>

            <div class="flex flex-col-reverse sm:flex-row items-center justify-between gap-4 mt-10">
                <a href="/cart" class="w-full sm:w-auto px-6 py-3 rounded-xl border border-gray-200 text-slate-600 font-semibold hover:bg-slate-50 hover:text-slate-900 focus:ring-2 focus:ring-slate-500/20 transition-all text-center">Back to Cart</a>
                <form action="/booking/<%= booking.id %>/confirm" method="POST" class="w-full sm:w-auto">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="w-full sm:w-auto px-8 py-3 rounded-xl bg-slate-900 text-white font-semibold hover:bg-slate-800 transition-all shadow-md flex justify-center items-center gap-2">
                        Confirm & Continue
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                    </button>
                </form>
            </div>
        </div>
    </div>
</body>
</html>
