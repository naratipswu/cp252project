<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Cart</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#f8f9fa] min-h-screen font-sans text-slate-800">
  <nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16 items-center">
        <div class="flex items-center gap-3">
            <div class="bg-indigo-600 p-2 rounded-lg">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
            </div>
            <a href="/browse" class="text-xl font-bold text-slate-900 tracking-tight hover:text-indigo-600 transition">Storefront</a>
            <span class="text-slate-400 font-medium">/</span>
            <span class="text-slate-500 font-medium">My Cart</span>
        </div>
        <div class="flex items-center gap-4">
          <a href="/profile" class="text-slate-600 hover:text-slate-900 text-sm font-medium transition">Profile</a>
          <span class="w-px h-4 bg-gray-300"></span>
          <form action="/logout" method="POST" class="inline m-0 p-0">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="bg-slate-900 hover:bg-slate-800 text-white px-4 py-1.5 rounded-lg text-sm font-semibold transition shadow-sm">Logout</button>
          </form>
        </div>
      </div>
    </div>
  </nav>

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="flex flex-col sm:flex-row sm:items-end justify-between mb-8 gap-4">
      <div>
        <h1 class="text-2xl font-bold text-slate-900 tracking-tight">Active Bookings</h1>
        <p class="text-sm text-slate-500 mt-1">รายการจองที่ยังไม่เสร็จสิ้น (Pending หรือ Active)</p>
      </div>
      <a href="/browse" class="px-5 py-2.5 rounded-lg bg-indigo-600 text-white font-semibold text-sm hover:bg-indigo-700 hover:shadow-md transition-all whitespace-nowrap">Browse More Items</a>
    </div>

    <% if (!items || items.length === 0) { %>
      <div class="bg-white rounded-2xl border border-gray-100 shadow-[0_2px_8px_-3px_rgba(0,0,0,0.05)] p-12 flex flex-col items-center justify-center text-center">
        <div class="w-16 h-16 bg-slate-50 text-slate-300 rounded-full flex items-center justify-center mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
        </div>
        <p class="text-lg font-semibold text-slate-700">Empty Cart</p>
        <p class="text-sm text-slate-500 mt-1">ไม่มีรายการรอการยืนยันหรือชำระเงินในขณะนี้</p>
      </div>
    <% } else { %>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <% items.forEach((item) => { %>
          <div class="bg-white border border-gray-100 rounded-2xl shadow-[0_2px_8px_-3px_rgba(0,0,0,0.05)] overflow-hidden transition-all hover:shadow-md hover:border-indigo-100 flex flex-col">
            <div class="flex gap-5 p-5">
              <div class="w-28 h-28 shrink-0 rounded-xl bg-slate-50 border border-gray-100 overflow-hidden flex items-center justify-center">
                <% if (item.camera.image) { %>
                  <img src="<%= item.camera.image %>" alt="camera" class="w-full h-full object-cover">
                <% } else { %>
                  <svg class="w-8 h-8 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                <% } %>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <h3 class="font-bold text-slate-900 text-lg truncate"><%= item.camera.brand %> <%= item.camera.model %></h3>
                    <div class="text-xs font-mono text-slate-400 mt-0.5">Rental #<%= item.rentalId %></div>
                  </div>
                  <div class="text-right shrink-0">
                    <div class="text-lg font-bold text-emerald-600"><%= Number(item.totalAmount).toLocaleString() %> ฿</div>
                    <div class="text-[11px] font-semibold uppercase tracking-wider mt-0.5 <%= item.paymentStatus === 'approved' ? 'text-emerald-500' : 'text-slate-500' %>"><%= item.paymentStatus %></div>
                  </div>
                </div>

                <div class="mt-4 grid grid-cols-2 gap-3">
                  <div class="bg-slate-50 border border-gray-100 rounded-lg p-2.5">
                    <div class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-0.5">Pick Up</div>
                    <div class="font-semibold text-slate-800 text-sm"><%= item.startDate %></div>
                  </div>
                  <div class="bg-slate-50 border border-gray-100 rounded-lg p-2.5">
                    <div class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-0.5">Return</div>
                    <div class="font-semibold text-slate-800 text-sm"><%= item.endDate %></div>
                  </div>
                </div>
              </div>
            </div>

            <div class="px-5 py-4 bg-slate-50/50 border-t border-gray-100 flex flex-wrap items-center justify-between gap-3 mt-auto">
              <div>
                <span class="inline-flex items-center px-2.5 py-1 rounded text-xs font-bold uppercase tracking-wider <%= item.rentalStatus === 'pending' ? 'bg-amber-100 text-amber-800' : 'bg-indigo-100 text-indigo-800' %>">
                  <%= item.rentalStatus %>
                </span>
              </div>

              <div class="flex flex-wrap items-center gap-2">
                <% if (item.rentalStatus === 'pending') { %>
                  <form action="/booking/<%= item.rentalId %>/confirm" method="POST">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="px-4 py-2.5 rounded-lg bg-slate-900 text-white font-semibold text-sm hover:bg-slate-800 transition-all shadow-sm">Confirm Booking</button>
                  </form>
                <% } %>

                <% if (item.rentalStatus === 'active' && item.paymentStatus === 'unpaid') { %>
                  <a href="/booking/<%= item.rentalId %>/payment" class="px-5 py-2.5 rounded-lg bg-emerald-600 text-white font-semibold text-sm hover:bg-emerald-700 transition-all shadow-sm">Pay Now</a>
                <% } %>

                <% if (item.rentalStatus === 'active' && item.paymentStatus === 'pending') { %>
                  <span class="px-4 py-2 rounded-lg bg-amber-50 text-amber-700 border border-amber-200 text-sm font-semibold">Pending Approval</span>
                <% } %>

                <% if (item.rentalStatus === 'active' && item.paymentStatus === 'rejected') { %>
                  <a href="/booking/<%= item.rentalId %>/payment" class="px-4 py-2.5 rounded-lg bg-red-600 text-white font-semibold text-sm hover:bg-red-700 transition-all shadow-sm">Re-upload Slip</a>
                <% } %>

                <% if (item.paymentStatus === 'unpaid') { %>
                  <form action="/cart/<%= item.rentalId %>/cancel" method="POST" onsubmit="return confirm('Cancel this booking?');">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="px-4 py-2.5 rounded-lg bg-white border border-gray-200 text-slate-700 font-semibold text-sm hover:bg-slate-50 hover:text-red-600 focus:ring-2 focus:ring-red-500/20 transition-all shadow-sm">Cancel</button>
                  </form>
                <% } %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

    <section class="mt-14">
      <div class="mb-6">
        <h2 class="text-xl font-bold text-slate-900 tracking-tight">Booking History</h2>
        <p class="text-sm text-slate-500 mt-1">ประวัติรายการที่เสร็จสิ้นหรือถูกยกเลิกแล้ว</p>
      </div>

      <% if (!historyItems || historyItems.length === 0) { %>
        <div class="bg-white rounded-2xl border border-gray-100 shadow-[0_2px_8px_-3px_rgba(0,0,0,0.05)] p-12 text-center text-slate-400 font-medium">
          ยังไม่มีประวัติการจอง
        </div>
      <% } else { %>
        <div class="bg-white rounded-2xl border border-gray-100 shadow-[0_2px_8px_-3px_rgba(0,0,0,0.05)] overflow-hidden">
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-100">
              <thead class="bg-slate-50/50">
                <tr>
                  <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Rental ID</th>
                  <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Camera</th>
                  <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Dates</th>
                  <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Total</th>
                  <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Status</th>
                  <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Slip</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-50 bg-white">
                <% historyItems.forEach((item) => { %>
                  <tr class="hover:bg-slate-50/50 transition-colors">
                    <td class="px-6 py-4 whitespace-nowrap font-mono text-xs text-slate-500">#<%= item.rentalId %></td>
                    <td class="px-6 py-4 whitespace-nowrap font-semibold text-slate-900"><%= item.camera.brand %> <%= item.camera.model %></td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600"><%= item.startDate %> <span class="text-slate-300 mx-1">to</span> <%= item.endDate %></td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-slate-900"><%= Number(item.totalAmount).toLocaleString() %> ฿</td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <div class="flex flex-col gap-1 items-start">
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-[11px] font-bold uppercase tracking-wider <%= item.rentalStatus === 'completed' ? 'bg-emerald-100 text-emerald-800' : 'bg-red-100 text-red-800' %>">
                          <%= item.rentalStatus %>
                        </span>
                        <span class="text-[10px] uppercase font-bold tracking-widest text-slate-400"><%= item.paymentStatus %></span>
                      </div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm">
                      <% if (item.slipPath) { %>
                        <a href="<%= item.slipPath %>" target="_blank" rel="noopener" class="text-indigo-600 hover:text-indigo-800 font-semibold underline decoration-indigo-200 underline-offset-4">View Slip</a>
                      <% } else { %>
                        <span class="text-slate-300">-</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      <% } %>
    </section>
  </main>
</body>
</html>

