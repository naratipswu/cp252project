<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Cart</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen">
  <nav class="bg-gray-900 shadow">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16 items-center">
        <div class="flex items-center gap-3">
          <a href="/browse" class="text-white font-bold">Back to Browse</a>
          <span class="text-gray-400 text-sm">Cart</span>
        </div>
        <div class="flex items-center gap-4">
          <a href="/profile" class="text-gray-200 hover:text-white text-sm">Profile</a>
          <form action="/logout" method="POST" class="inline">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="text-gray-200 hover:text-white text-sm">Logout</button>
          </form>
        </div>
      </div>
    </div>
  </nav>

  <main class="max-w-6xl mx-auto p-6">
    <div class="flex items-end justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">My Cart</h1>
        <p class="text-sm text-gray-500">รายการจองที่ยังไม่เสร็จสิ้น (pending/active)</p>
      </div>
      <a href="/browse" class="px-4 py-2 rounded bg-black text-white hover:bg-gray-800 transition">Browse more</a>
    </div>

    <% if (!items || items.length === 0) { %>
      <div class="bg-white border rounded-lg p-10 text-center text-gray-600">
        ไม่มีรายการในตะกร้า
      </div>
    <% } else { %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <% items.forEach((item) => { %>
          <div class="bg-white border rounded-2xl shadow-sm overflow-hidden">
            <div class="flex gap-4 p-4">
              <div class="w-28 h-20 rounded-lg bg-gray-100 overflow-hidden flex items-center justify-center">
                <% if (item.camera.image) { %>
                  <img src="<%= item.camera.image %>" alt="camera" class="w-full h-full object-cover">
                <% } else { %>
                  <span class="text-xs text-gray-500">No image</span>
                <% } %>
              </div>
              <div class="flex-1">
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <div class="font-semibold text-gray-900"><%= item.camera.brand %> <%= item.camera.model %></div>
                    <div class="text-xs text-gray-500">Rental ID: <%= item.rentalId %></div>
                  </div>
                  <div class="text-right">
                    <div class="text-sm font-bold text-gray-900"><%= item.totalAmount %> THB</div>
                    <div class="text-xs text-gray-500">Payment: <%= item.paymentStatus %></div>
                  </div>
                </div>

                <div class="mt-3 grid grid-cols-2 gap-2 text-sm">
                  <div class="bg-gray-50 rounded p-2">
                    <div class="text-xs text-gray-500">Start</div>
                    <div class="font-medium text-gray-800"><%= item.startDate %></div>
                  </div>
                  <div class="bg-gray-50 rounded p-2">
                    <div class="text-xs text-gray-500">End</div>
                    <div class="font-medium text-gray-800"><%= item.endDate %></div>
                  </div>
                </div>

                <div class="mt-3 flex items-center justify-between gap-2">
                  <div class="text-xs">
                    <span class="px-2 py-1 rounded-full <%= item.rentalStatus === 'pending' ? 'bg-yellow-100 text-yellow-800' : 'bg-blue-100 text-blue-800' %>">
                      <%= item.rentalStatus %>
                    </span>
                  </div>

                  <div class="flex items-center gap-2">
                    <% if (item.rentalStatus === 'pending') { %>
                      <form action="/booking/<%= item.rentalId %>/confirm" method="POST">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button type="submit" class="px-3 py-2 rounded bg-gray-900 text-white text-sm hover:bg-gray-700 transition">Confirm</button>
                      </form>
                    <% } %>

                    <% if (item.rentalStatus === 'active' && item.paymentStatus === 'unpaid') { %>
                      <a href="/booking/<%= item.rentalId %>/payment" class="px-3 py-2 rounded bg-emerald-600 text-white text-sm hover:bg-emerald-500 transition">Pay</a>
                    <% } %>

                    <% if (item.rentalStatus === 'active' && item.paymentStatus === 'pending') { %>
                      <span class="px-3 py-2 rounded bg-amber-100 text-amber-800 text-sm">Pending approval</span>
                    <% } %>

                    <% if (item.rentalStatus === 'active' && item.paymentStatus === 'rejected') { %>
                      <a href="/booking/<%= item.rentalId %>/payment" class="px-3 py-2 rounded bg-red-600 text-white text-sm hover:bg-red-500 transition">Re-upload Slip</a>
                    <% } %>

                    <% if (item.paymentStatus === 'unpaid') { %>
                      <form action="/cart/<%= item.rentalId %>/cancel" method="POST" onsubmit="return confirm('Cancel this booking?');">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button type="submit" class="px-3 py-2 rounded border border-gray-300 text-gray-700 text-sm hover:bg-gray-50 transition">Cancel</button>
                      </form>
                    <% } %>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

    <section class="mt-10">
      <div class="flex items-end justify-between mb-4">
        <div>
          <h2 class="text-xl font-bold text-gray-900">Booking History</h2>
          <p class="text-sm text-gray-500">รายการที่เสร็จสิ้นหรือถูกยกเลิก</p>
        </div>
      </div>

      <% if (!historyItems || historyItems.length === 0) { %>
        <div class="bg-white border rounded-lg p-8 text-center text-gray-600">
          ยังไม่มีประวัติการจอง
        </div>
      <% } else { %>
        <div class="bg-white border rounded-2xl shadow-sm overflow-hidden">
          <div class="overflow-x-auto">
            <table class="min-w-full text-sm">
              <thead class="bg-gray-50 text-gray-600">
                <tr>
                  <th class="text-left px-4 py-3 border-b">Rental</th>
                  <th class="text-left px-4 py-3 border-b">Camera</th>
                  <th class="text-left px-4 py-3 border-b">Dates</th>
                  <th class="text-left px-4 py-3 border-b">Total</th>
                  <th class="text-left px-4 py-3 border-b">Booking</th>
                  <th class="text-left px-4 py-3 border-b">Payment</th>
                  <th class="text-left px-4 py-3 border-b">Slip</th>
                </tr>
              </thead>
              <tbody>
                <% historyItems.forEach((item) => { %>
                  <tr class="odd:bg-white even:bg-gray-50/70">
                    <td class="px-4 py-3 border-b border-gray-100 font-medium text-gray-800">#<%= item.rentalId %></td>
                    <td class="px-4 py-3 border-b border-gray-100 text-gray-800"><%= item.camera.brand %> <%= item.camera.model %></td>
                    <td class="px-4 py-3 border-b border-gray-100 text-gray-700"><%= item.startDate %> - <%= item.endDate %></td>
                    <td class="px-4 py-3 border-b border-gray-100 font-semibold text-gray-900"><%= item.totalAmount %> THB</td>
                    <td class="px-4 py-3 border-b border-gray-100">
                      <span class="px-2 py-1 rounded-full text-xs <%= item.rentalStatus === 'completed' ? 'bg-emerald-100 text-emerald-800' : 'bg-red-100 text-red-800' %>">
                        <%= item.rentalStatus %>
                      </span>
                    </td>
                    <td class="px-4 py-3 border-b border-gray-100 text-gray-700"><%= item.paymentStatus %></td>
                    <td class="px-4 py-3 border-b border-gray-100">
                      <% if (item.slipPath) { %>
                        <a href="<%= item.slipPath %>" target="_blank" rel="noopener" class="text-blue-600 hover:text-blue-800 underline">View slip</a>
                      <% } else { %>
                        <span class="text-gray-400">-</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      <% } %>
    </section>
  </main>
</body>
</html>

