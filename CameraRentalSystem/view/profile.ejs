<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen text-gray-900">
    <div class="max-w-4xl mx-auto py-10 px-4">
        <div class="flex items-center justify-between mb-6">
            <h1 class="text-3xl font-bold">My Profile</h1>
            <div class="flex items-center gap-3">
                <a href="/browse" class="px-4 py-2 bg-black text-white rounded hover:bg-gray-800 transition">Back to Browse</a>
                <form action="/logout" method="POST">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700 transition">Logout</button>
                </form>
            </div>
        </div>

        <section class="bg-white rounded-lg shadow p-6 mb-8">
            <h2 class="text-xl font-semibold mb-4">Account Info</h2>
            <div class="mb-5 flex items-center gap-4">
                <% if (user.avatar) { %>
                    <img src="<%= user.avatar %>" alt="avatar" class="w-20 h-20 rounded-full object-cover border">
                <% } else { %>
                    <div class="w-20 h-20 rounded-full border bg-gray-200 flex items-center justify-center text-gray-600 text-sm">No avatar</div>
                <% } %>
                <form action="/profile/avatar" method="POST" enctype="multipart/form-data" class="flex items-center gap-2">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <input type="hidden" name="category" value="avatars">
                    <input type="file" name="avatarFile" accept=".jpg,.jpeg,.png,.webp,.gif,.svg" class="text-sm" required>
                    <button type="submit" class="px-3 py-2 bg-blue-600 text-white rounded hover:bg-blue-500 transition">Update Avatar</button>
                </form>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <p><span class="font-semibold">Username:</span> <%= user.username %></p>
                <p><span class="font-semibold">Email:</span> <%= user.email %></p>
                <p><span class="font-semibold">Role:</span> <%= user.role %></p>
                <p><span class="font-semibold">Avatar path:</span> <%= user.avatar || '-' %></p>
            </div>
        </section>

        <section class="bg-white rounded-lg shadow p-6">
            <h2 class="text-xl font-semibold mb-4">My Bookings</h2>
            <% if (bookings.length === 0) { %>
                <p class="text-gray-600">You do not have any bookings yet.</p>
            <% } else { %>
                <div class="overflow-x-auto">
                    <table class="min-w-full border border-gray-200 text-sm">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="text-left px-4 py-2 border-b">Camera</th>
                                <th class="text-left px-4 py-2 border-b">Dates</th>
                                <th class="text-left px-4 py-2 border-b">Price</th>
                                <th class="text-left px-4 py-2 border-b">Booking</th>
                                <th class="text-left px-4 py-2 border-b">Payment</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% bookings.forEach((booking) => { %>
                                <tr class="odd:bg-white even:bg-gray-50">
                                    <td class="px-4 py-2 border-b"><%= booking.cameraModel %></td>
                                    <td class="px-4 py-2 border-b"><%= booking.startDate %> to <%= booking.endDate %></td>
                                    <td class="px-4 py-2 border-b"><%= booking.totalPrice %> THB</td>
                                    <td class="px-4 py-2 border-b"><%= booking.bookingStatus %></td>
                                    <td class="px-4 py-2 border-b"><%= booking.paymentStatus %></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </section>
    </div>
</body>
</html>
