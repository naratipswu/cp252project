<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#f8f9fa] min-h-screen font-sans text-slate-800">
    <nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex items-center gap-3">
                    <div class="bg-indigo-600 p-2 rounded-lg">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                    </div>
                    <h1 class="text-xl font-bold text-slate-900 tracking-tight">My Profile</h1>
                </div>
                <div class="flex items-center gap-4">
                    <a href="/browse" class="text-slate-600 hover:text-slate-900 text-sm font-medium transition">Storefront</a>
                    <span class="w-px h-4 bg-gray-300"></span>
                    <form action="/logout" method="POST" class="inline m-0 p-0">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button type="submit" class="bg-slate-900 hover:bg-slate-800 text-white px-4 py-1.5 rounded-lg text-sm font-semibold transition shadow-sm">Logout</button>
                    </form>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-4xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
        <div class="mb-8">
            <h2 class="text-2xl font-bold text-slate-900 tracking-tight">Account Overview</h2>
            <p class="text-sm text-slate-500 mt-1">Manage your personal information and adjust your preferences.</p>
        </div>

        <section class="bg-white rounded-2xl shadow-[0_2px_8px_-3px_rgba(0,0,0,0.05)] border border-gray-100 p-8 mb-8">
            <h3 class="text-lg font-bold text-slate-800 tracking-tight mb-6 border-b border-gray-50 pb-4">Personal Details</h3>
            
            <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6 mb-8 border-b border-gray-50 pb-8">
                <div class="relative group">
                    <% if (user.avatar) { %>
                        <img src="<%= user.avatar %>" alt="avatar" class="w-24 h-24 rounded-full object-cover border-4 border-white shadow-md">
                    <% } else { %>
                        <div class="w-24 h-24 rounded-full border-4 border-white shadow-md bg-slate-100 flex items-center justify-center text-slate-400">
                            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                        </div>
                    <% } %>
                </div>
                <div class="flex-1 w-full sm:w-auto">
                    <p class="text-sm font-semibold text-slate-700 mb-2">Profile Picture</p>
                    <form action="/profile/avatar" method="POST" enctype="multipart/form-data" class="flex flex-col sm:flex-row items-center gap-3">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <input type="hidden" name="category" value="avatars">
                        <input type="file" name="avatarFile" accept=".jpg,.jpeg,.png,.webp,.gif,.svg" class="w-full sm:w-auto border border-gray-200 rounded-lg px-3 py-1.5 text-sm focus:outline-none file:mr-3 file:py-1 file:px-3 file:rounded-md file:border-0 file:text-xs file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100 cursor-pointer" required>
                        <button type="submit" class="w-full sm:w-auto px-4 py-2 bg-indigo-600 text-white font-semibold text-sm rounded-lg hover:bg-indigo-700 transition shadow-sm whitespace-nowrap">Upload Avatar</button>
                    </form>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Username</label>
                    <div class="font-medium text-slate-900 bg-slate-50 border border-gray-100 rounded-lg px-4 py-2.5"><%= user.username %></div>
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Email Address</label>
                    <div class="font-medium text-slate-900 bg-slate-50 border border-gray-100 rounded-lg px-4 py-2.5"><%= user.email %></div>
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Account Role</label>
                    <div class="inline-flex items-center px-3 py-1 rounded bg-slate-100 text-slate-700 text-sm font-semibold capitalize mt-1"><%= user.role %></div>
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Avatar Path</label>
                    <div class="font-mono text-xs text-slate-500 bg-slate-50 border border-gray-100 rounded-lg px-4 py-3 truncate" title="<%= user.avatar || '-' %>"><%= user.avatar || 'Not uploaded' %></div>
                </div>
            </div>
        </section>

        <a href="/cart" class="block w-full">
            <div class="bg-gradient-to-r from-blue-50 to-indigo-50 border border-blue-100/50 rounded-2xl p-6 transition-all hover:shadow-md hover:border-blue-200 group flex items-center justify-between">
                <div>
                    <h3 class="text-base font-bold text-blue-900">View Bookings & History</h3>
                    <p class="text-sm text-blue-700/80 mt-1">Check your current reservations and past rental history.</p>
                </div>
                <div class="bg-white p-3 rounded-full shadow-sm group-hover:scale-110 transition-transform">
                    <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                </div>
            </div>
        </a>

        <% if (user.role === 'admin') { %>
            <a href="/admin" class="block w-full mt-4">
                <div class="bg-gradient-to-r from-purple-50 to-pink-50 border border-purple-100/50 rounded-2xl p-6 transition-all hover:shadow-md hover:border-purple-200 group flex flex-col md:flex-row md:items-center justify-between gap-4">
                    <div>
                        <h3 class="text-base font-bold text-purple-900">Admin Control Center</h3>
                        <p class="text-sm text-purple-700/80 mt-1">Access the main dashboard to oversee the system and manage settings.</p>
                    </div>
                    <div class="inline-flex items-center justify-center px-5 py-2.5 rounded-lg bg-purple-700 text-white font-semibold text-sm transition-all group-hover:bg-purple-800 shadow-sm gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        Admin Dashboard
                    </div>
                </div>
            </a>
        <% } %>
    </main>
</body>
</html>
