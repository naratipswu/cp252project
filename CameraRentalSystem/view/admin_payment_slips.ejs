<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Slip Review</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#f8f9fa] min-h-screen font-sans text-slate-800">
    <nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex items-center gap-3">
                    <div class="bg-slate-900 p-2 rounded-lg">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                    </div>
                    <h1 class="text-xl font-bold text-slate-900 tracking-tight">Review Payment Slips</h1>
                </div>
                <div class="flex items-center gap-4">
                    <a href="/admin" class="text-indigo-600 hover:text-indigo-800 text-sm font-semibold transition">Back to Dashboard</a>
                    <span class="w-px h-4 bg-gray-300"></span>
                    <span class="text-slate-500 text-sm">Admin: <%= user.username %></span>
                </div>
            </div>
        </div>
    </nav>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-8">
        <h2 class="text-2xl font-bold text-slate-900 tracking-tight">Payment Validations</h2>
        <p class="text-sm text-slate-500 mt-1">Review user-uploaded slips and approve or reject transactions.</p>
    </div>

    <% if (!slips || slips.length === 0) { %>
      <div class="bg-white rounded-2xl border border-gray-100 shadow-[0_2px_8px_-3px_rgba(0,0,0,0.05)] p-12 flex flex-col items-center justify-center text-center">
        <div class="w-16 h-16 bg-slate-50 text-slate-300 rounded-full flex items-center justify-center mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
        </div>
        <p class="text-lg font-semibold text-slate-700">No pending payments</p>
        <p class="text-sm text-slate-500 mt-1">All good! No payment slips have been submitted for review yet.</p>
      </div>
    <% } else { %>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <% slips.forEach((slip) => { %>
          <section class="bg-white border border-gray-100 rounded-2xl shadow-[0_2px_8px_-3px_rgba(0,0,0,0.05)] overflow-hidden transition-all hover:shadow-md">
            <div class="p-5 border-b border-gray-100 bg-slate-50/50 flex items-start justify-between">
              <div>
                <p class="text-[13px] font-semibold text-slate-500 uppercase tracking-wider mb-1">Receipt Information</p>
                <h3 class="text-lg font-bold text-slate-900">Payment #<%= slip.paymentId %></h3>
                <p class="text-sm text-slate-500 mt-0.5">Booking #<%= slip.rentalId %> • <%= slip.paymentDate %></p>
              </div>
              <span class="px-3 py-1 text-xs font-bold rounded-md border <%= slip.paymentStatus === 'pending' ? 'bg-amber-100/50 text-amber-700 border-amber-200' : (slip.paymentStatus === 'approved' ? 'bg-emerald-100/50 text-emerald-700 border-emerald-200' : 'bg-red-100/50 text-red-700 border-red-200') %> uppercase tracking-wider">
                <%= slip.paymentStatus %>
              </span>
            </div>

            <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="space-y-3 text-sm">
                <div class="flex justify-between border-b border-gray-100 pb-2"><span class="text-slate-500">Renter</span> <span class="font-semibold text-slate-900"><%= slip.customer.username %></span></div>
                <div class="flex justify-between border-b border-gray-100 pb-2"><span class="text-slate-500">Email</span> <span class="font-semibold text-slate-900 text-right max-w-[150px] truncate" title="<%= slip.customer.email %>"><%= slip.customer.email %></span></div>
                <div class="flex justify-between border-b border-gray-100 pb-2"><span class="text-slate-500">Camera</span> <span class="font-semibold text-slate-900 text-right"><%= slip.booking.cameraModel %></span></div>
                <div class="flex flex-col border-b border-gray-100 pb-2 gap-1"><span class="text-slate-500">Dates</span> <span class="font-semibold text-slate-900 text-xs"><%= slip.booking.startDate %> <span class="text-slate-400 font-normal">to</span> <%= slip.booking.endDate %></span></div>
                <div class="flex justify-between border-b border-gray-100 pb-2"><span class="text-slate-500">Amount</span> <span class="font-bold text-emerald-600 text-lg"><%= Number(slip.amount).toLocaleString() %> ฿</span></div>
                <div class="flex justify-between"><span class="text-slate-500">Rental Status</span> <span class="font-semibold text-slate-700"><%= slip.rentalStatus %></span></div>
              </div>

              <div class="flex items-center justify-center bg-slate-50 rounded-xl min-h-48 border border-gray-100 p-2 relative group overflow-hidden">
                <% if (slip.slipPath) { %>
                  <a href="<%= slip.slipPath %>" target="_blank" rel="noopener" class="block w-full h-full relative z-10">
                    <img src="<%= slip.slipPath %>" alt="Slip" class="w-full h-full object-cover rounded-lg shadow-sm group-hover:scale-105 transition-transform duration-300">
                  </a>
                  <div class="absolute inset-0 bg-slate-900/10 opacity-0 group-hover:opacity-100 transition-opacity z-20 pointer-events-none flex items-center justify-center">
                    <span class="bg-slate-900/80 text-white text-xs font-semibold px-3 py-1.5 rounded-lg shadow-lg">Click to enlarge</span>
                  </div>
                <% } else { %>
                  <div class="flex flex-col items-center justify-center text-slate-400">
                    <svg class="w-8 h-8 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    <span class="text-sm font-medium">No slip file attached</span>
                  </div>
                <% } %>
              </div>
            </div>

            <% if (slip.paymentStatus === 'pending') { %>
              <div class="p-6 pt-0 mt-2 grid grid-cols-1 md:grid-cols-2 gap-3">
                <form action="/admin/payment-slips/<%= slip.paymentId %>/approve" method="POST" onsubmit="return confirm('Approve this payment slip?');">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="w-full py-2.5 rounded-lg bg-emerald-600 text-white font-semibold text-sm hover:bg-emerald-700 hover:shadow-md transition-all flex items-center justify-center gap-2">
                    <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                    Approve Slip
                  </button>
                </form>
                <form action="/admin/payment-slips/<%= slip.paymentId %>/reject" method="POST" onsubmit="return confirm('Reject this slip (suspected fake)?');">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="w-full py-2.5 rounded-lg bg-red-50 text-red-700 border border-red-200 font-semibold text-sm hover:bg-red-100 transition-all flex items-center justify-center gap-2">
                    <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                    Reject Slip
                  </button>
                </form>
              </div>
            <% } %>
          </section>
        <% }) %>
      </div>
    <% } %>
  </main>
</body>
</html>
