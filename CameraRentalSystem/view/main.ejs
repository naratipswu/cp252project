<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Camera Rental System</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@400;700;900&display=swap"
        rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        .font-serif-elegant {
            font-family: 'Playfair Display', serif;
        }

        .bg-brand-brown {
            background-color: #1a150d;
        }

        .text-brand-yellow {
            color: #d69e2e;
        }

        .bg-brand-yellow {
            background-color: #d69e2e;
        }

        .bg-hero {
            background-image: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.5)), url('https://images.unsplash.com/photo-1512790182412-b19e6d62bc39?auto=format&fit=crop&q=80&w=1920');
            background-size: cover;
            background-position: center;
        }
    </style>
</head>

<body class="bg-brand-brown text-white min-h-screen relative">

    <!-- Navbar -->
    <nav class="flex h-16 w-full">
        <!-- Logo Area -->
        <div
            class="bg-brand-yellow text-black font-black text-lg md:text-xl flex items-center justify-center px-6 md:px-10 tracking-wider">
            CAMERA TYPE
        </div>

        <!-- Navigation Links -->
        <div class="flex-1 bg-[#222] flex items-center justify-start px-8 gap-8 hidden md:flex">
            <a href="/browse?type=digital" class="text-white font-bold tracking-wider hover:text-brand-yellow transition">DIGITAL</a>
            <a href="/browse?type=film" class="text-white font-bold tracking-wider hover:text-brand-yellow transition">FILM</a>
            <a href="#" class="text-white font-bold tracking-wider hover:text-brand-yellow transition">PHOTO</a>
            <a href="/process" class="text-white font-bold tracking-wider hover:text-brand-yellow transition">PROCESS</a>
            <a href="/contact" class="text-white font-bold tracking-wider hover:text-brand-yellow transition">CONTACT</a>
        </div>

        <!-- Icons Area -->
        <div class="bg-white text-black flex items-center justify-center px-6 gap-6 ml-auto md:ml-0">
            <a href="<%= user ? '/profile' : '/signin' %>" class="hover:text-gray-600 transition" title="<%= user ? 'Profile' : 'Sign in' %>">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                </svg>
            </a>
            <% if (user) { %>
                <form action="/logout" method="POST" class="inline">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="hover:text-red-600 transition font-semibold text-sm">Logout</button>
                </form>
            <% } %>
            <a href="/cart" class="hover:text-gray-600 transition" title="Cart">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z">
                    </path>
                </svg>
            </a>
        </div>
    </nav>

    <!-- Hero Section -->
    <header class="h-[70vh] bg-hero flex flex-col items-center justify-center text-center px-4">
        <h1 class="font-serif-elegant text-5xl md:text-7xl mb-2 text-white drop-shadow-lg">CAPTURE MOMENTS</h1>
        <h1 class="font-serif-elegant text-5xl md:text-7xl mb-6 text-white drop-shadow-lg">THE OLD WAY</h1>
        <p class="font-serif-elegant text-lg md:text-2xl mb-8 italic text-gray-200">Rent vintage cameras for your story.
        </p>

        <a href="/browse"
            class="bg-black text-white px-8 py-3 rounded-full font-medium hover:bg-gray-800 transition tracking-wide shadow-xl border border-gray-700">
            Browse Cameras
        </a>
    </header>

    <!-- Brands Section -->
    <section class="max-w-7xl mx-auto px-6 py-12">
        <h2 class="text-2xl font-bold mb-4">Brand</h2>
        <div class="h-px bg-white/30 w-full mb-10"></div>

        <!-- Mock Logos -->
        <div class="flex flex-wrap items-center justify-between gap-8 md:gap-16 opacity-90 mb-10">
            <div class="text-4xl md:text-5xl font-black tracking-tighter">Canon</div>
            <div class="text-4xl md:text-5xl font-black tracking-widest uppercase">FUJIFILM</div>
            <div class="text-4xl md:text-5xl font-bold tracking-widest">SONY<span class="text-sm align-top">®</span>
            </div>
            <div class="text-4xl md:text-5xl font-black font-serif-elegant">Kodak</div>
        </div>

        <div class="h-px bg-white/30 w-full mb-10"></div>
        <h2 class="text-2xl font-bold mb-4">Category...</h2>
    </section>

</body>

</html>