<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&display=swap" rel="stylesheet">
    <style>
        .font-serif-elegant { font-family: 'Playfair Display', serif; }
        .bg-left-panel { background-color: #1a1a1a; }
        .bg-right-panel { background-color: #262626; }
        .bg-input-gray { background-color: #D9D9D9; }
        .text-yellow-link { color: #d69e2e; }
        .bg-hero {
            background-image: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.5)), url('https://images.unsplash.com/photo-1512790182412-b19e6d62bc39?auto=format&fit=crop&q=80&w=1920');
            background-size: cover;
            background-position: center;
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center text-white font-serif-elegant bg-hero p-4">

    <!-- Floating Block (Card) -->
    <div class="flex max-w-5xl w-full mx-auto rounded-xl overflow-hidden shadow-[0_20px_50px_rgba(0,0,0,0.7)]">
        
        <!-- Left Panel -->
        <div class="hidden md:flex flex-col items-center justify-center w-1/2 bg-left-panel p-12 text-center h-[650px] z-10 shadow-[5px_0_15px_-3px_rgba(0,0,0,0.5)]">
            <h1 class="text-4xl lg:text-5xl mb-4 tracking-wide text-white">CAPTURE MOMENTS</h1>
            <h1 class="text-4xl lg:text-5xl tracking-wide text-white">THE OLD WAY</h1>
        </div>

        <!-- Right Panel -->
        <div class="w-full md:w-1/2 bg-right-panel flex flex-col justify-center px-10 py-10 h-[650px]">
            <div class="max-w-md w-full mx-auto">
                
                <!-- Exact Match to signin.png which acts as Register -->
                <h2 class="text-4xl tracking-wide mb-2">Sign In</h2>
                <p class="text-xs font-sans text-gray-300 mb-8 font-light">กรุณาลงทะเบียนเข้าสู่ระบบเพื่อทำการจองอุปกรณ์</p>

                <form action="/login/google" method="POST" class="space-y-4">
                    <!-- Username -->
                    <div>
                        <label class="block text-lg mb-1 tracking-wide">Username</label>
                        <input type="text" name="username" class="w-full h-10 bg-input-gray text-black px-4 focus:outline-none" required>
                    </div>

                    <!-- Password -->
                    <div>
                        <label class="block text-lg mb-1 tracking-wide">Password</label>
                        <input type="password" name="password" class="w-full h-10 bg-input-gray text-black px-4 focus:outline-none" required>
                    </div>

                    <!-- Email -->
                    <div>
                        <label class="block text-lg mb-1 tracking-wide">Email</label>
                        <input type="email" name="email" class="w-full h-10 bg-input-gray text-black px-4 focus:outline-none" required>
                    </div>

                    <!-- Submit Button -->
                    <div class="flex justify-center mt-6">
                        <button type="submit" class="bg-input-gray text-black text-lg py-2 px-12 tracking-wide hover:bg-gray-300 transition">
                            REGISTER
                        </button>
                    </div>
                </form>

                <div class="text-center mt-6 text-xs font-sans">
                    <span class="text-gray-300">already sign up ?</span> 
                    <a href="/signin" class="text-yellow-link font-serif-elegant ml-1 hover:underline text-sm">sign in</a>
                </div>

                <div class="border-t border-gray-500 mt-6 mb-6 max-w-sm mx-auto"></div>

                <!-- Social Buttons -->
                <div class="flex justify-center gap-6">
                    <form action="/login/google" method="POST" class="inline">
                        <input type="hidden" name="email" value="google-register@gmail.com">
                        <button type="submit" class="w-10 h-10 bg-input-gray rounded-full cursor-pointer hover:bg-gray-300 transition"></button>
                    </form>
                    <div class="w-10 h-10 bg-input-gray rounded-full cursor-pointer hover:bg-gray-300 transition"></div>
                    <div class="w-10 h-10 bg-input-gray rounded-full cursor-pointer hover:bg-gray-300 transition"></div>
                </div>

            </div>
        </div>
        
    </div>

</body>
</html>
