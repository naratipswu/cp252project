<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Media Manager</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen">
  <main class="max-w-4xl mx-auto p-6">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-2xl font-bold text-gray-900">Media Manager</h1>
      <div class="flex items-center gap-2">
        <a href="/main" class="px-4 py-2 bg-emerald-600 text-white rounded hover:bg-emerald-500 transition">Go to Main</a>
        <a href="/browse" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-500 transition">Go to Browse</a>
        <a href="/admin" class="px-4 py-2 bg-gray-900 text-white rounded hover:bg-gray-700 transition">Back to Admin</a>
      </div>
    </div>

    <div class="bg-white rounded-lg border shadow p-6 mb-6">
      <h2 class="text-lg font-semibold mb-4">Upload Image</h2>

      <% if (error) { %>
        <p class="mb-4 text-red-600 font-medium"><%= error %></p>
      <% } %>
      <% if (uploaded) { %>
        <p class="mb-4 text-green-700 font-medium">Uploaded: <code><%= uploaded %></code></p>
        <img src="<%= uploaded %>" alt="uploaded file" class="w-56 h-40 object-cover rounded border">
      <% } %>

      <form action="/admin/media/upload" method="POST" enctype="multipart/form-data" class="space-y-4 mt-4">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <div>
          <label class="block mb-1 font-medium text-gray-700">Category</label>
          <select name="category" class="w-full border rounded px-3 py-2" required>
            <% categories.forEach((category) => { %>
              <option value="<%= category %>"><%= category %></option>
            <% }) %>
          </select>
        </div>

        <div>
          <label class="block mb-1 font-medium text-gray-700">Bind to Product Camera (optional)</label>
          <select name="cameraId" class="w-full border rounded px-3 py-2">
            <option value="">No binding</option>
            <% cameras.forEach((camera) => { %>
              <option value="<%= camera.id %>"><%= camera.brand %> <%= camera.model %> (ID <%= camera.id %>)</option>
            <% }) %>
          </select>
          <p class="text-xs text-gray-500 mt-1">If category is <code>products</code> and camera is selected, system updates camera image path automatically.</p>
        </div>

        <div>
          <label class="block mb-1 font-medium text-gray-700">Image File</label>
          <input type="file" name="imageFile" accept=".jpg,.jpeg,.png,.webp,.gif,.svg" class="w-full border rounded px-3 py-2" required>
        </div>

        <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-500 transition">Upload & Rename</button>
      </form>
    </div>

    <div class="bg-white rounded-lg border shadow p-6">
      <h2 class="text-lg font-semibold mb-3">Folder Structure</h2>
      <pre class="bg-gray-50 border rounded p-3 text-sm text-gray-700">public/
  uploads/
    products/
    website/
    slips/
    avatars/
    others/</pre>
    </div>
  </main>
</body>
</html>
