<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Asset Library | Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-[#f8fafc] min-h-screen text-slate-800">
    <!-- Navbar -->
    <nav class="bg-white border-b border-slate-200 sticky top-0 z-30 shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex items-center gap-3">
                    <div class="bg-purple-600 p-2 rounded-lg shadow-lg shadow-purple-100">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    </div>
                    <div>
                        <h1 class="text-xl font-extrabold text-slate-900 tracking-tight">Asset Library</h1>
                        <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest leading-none mt-0.5">Media Assets</p>
                    </div>
                </div>
                <div class="flex items-center gap-2">
                    <a href="/admin" class="px-4 py-2 text-sm font-bold border border-slate-200 text-slate-600 hover:bg-slate-900 hover:text-white rounded-lg transition-all shadow-sm">Dashboard</a>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 animate-[fadeIn_0.5s_ease-out]">
        
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Upload Side -->
            <aside class="lg:col-span-1">
                <div class="sticky top-24">
                    <header class="mb-6">
                        <h2 class="text-2xl font-black text-slate-900 tracking-tight">Upload Center</h2>
                        <p class="text-sm font-medium text-slate-500 mt-1">Add new files to the system storage</p>
                    </header>

                    <div class="bg-white rounded-2xl p-6 border border-slate-200 shadow-sm">
                        <form action="/admin/media/upload" method="POST" enctype="multipart/form-data" class="space-y-4">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            
                            <div class="relative group">
                                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 ml-1">Destination</label>
                                <select name="dir" class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl px-4 py-2.5 text-xs font-bold text-slate-700 outline-none focus:ring-4 focus:ring-purple-500/10 focus:border-purple-500 transition-all appearance-none cursor-pointer">
                                    <option value="public/images">Project Roots (Images)</option>
                                    <option value="public/uploads">Dynamic Uploads</option>
                                </select>
                                <div class="absolute right-4 top-9 pointer-events-none text-slate-300">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                </div>
                            </div>

                            <div class="border-2 border-dashed border-slate-100 rounded-2xl p-8 hover:border-purple-400 hover:bg-purple-50 group/drop transition-all duration-300 relative overflow-hidden">
                                <input type="file" name="file" required class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10">
                                <div class="text-center relative z-0 pointer-events-none">
                                    <div class="bg-slate-50 w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-4 group-hover/drop:bg-purple-600 transition-colors">
                                        <svg class="w-6 h-6 text-slate-400 group-hover/drop:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                                    </div>
                                    <p class="text-xs font-black text-slate-900 group-hover/drop:text-purple-700 transition-colors mb-1">CHOOSE FILE</p>
                                    <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest">or drag & drop here</p>
                                </div>
                            </div>

                            <button type="submit" class="w-full bg-slate-900 text-white text-xs font-black uppercase tracking-widest py-4 rounded-2xl shadow-lg shadow-slate-100 active:scale-95 transition-all hover:bg-purple-600 hover:shadow-purple-200">
                                Start Upload
                            </button>
                        </form>
                    </div>
                </div>
            </aside>

            <!-- Explorer Side -->
            <section class="lg:col-span-2">
                <header class="mb-6 flex items-center justify-between">
                    <div>
                        <h2 class="text-2xl font-black text-slate-900 tracking-tight">File Explorer</h2>
                        <p class="text-sm font-medium text-slate-500 mt-1">Browse and visualize your directory structure</p>
                    </div>
                    <div class="h-10 w-10 rounded-full bg-slate-50 border border-slate-100 flex items-center justify-center text-slate-400">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path></svg>
                    </div>
                </header>

                <div class="bg-white rounded-3xl border border-slate-200 shadow-sm overflow-hidden min-h-[400px]">
                    <div class="p-8">
                        <pre class="font-mono text-sm text-slate-600 leading-relaxed overflow-x-auto whitespace-pre-wrap"><%= structure %></pre>
                    </div>
                    
                    <% if (!structure || structure.trim() === '') { %>
                        <div class="flex flex-col items-center justify-center p-20 text-center">
                            <div class="bg-slate-50 p-6 rounded-full mb-4">
                                <svg class="w-10 h-10 text-slate-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 13h6m-3-3v6m-9 1V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"></path></svg>
                            </div>
                            <h3 class="text-lg font-bold text-slate-900">Virtual path missing</h3>
                            <p class="text-sm text-slate-400 font-medium">The directory structure could not be resolved or is empty.</p>
                        </div>
                    <% } %>
                </div>

                <div class="mt-6 flex items-start gap-4 p-4 bg-indigo-50/50 rounded-2xl border border-indigo-100/50">
                    <div class="p-2 bg-indigo-500 text-white rounded-lg shadow-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <div>
                        <h4 class="text-[11px] font-black text-indigo-900 uppercase tracking-widest mb-0.5">Asset Security</h4>
                        <p class="text-xs text-indigo-700/70 font-medium leading-relaxed">All uploaded assets are automatically processed and served via the public middleware. Ensure file names do not contain spaces for best compatibility.</p>
                    </div>
                </div>
            </section>
        </div>
    </main>

    <style>
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</body>
</html>
