<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Browse Cameras - Camera Rental</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .card-hover { transition: transform 0.2s ease, box-shadow 0.2s ease; }
        .card-hover:hover { transform: translateY(-4px); box-shadow: 0 20px 40px rgba(0,0,0,0.12); }
    </style>
</head>
<body class="bg-gray-50 min-h-screen">

    <!-- Navbar -->
    <nav class="bg-gray-900 shadow sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex items-center gap-6">
                    <a href="/" class="text-yellow-400 font-black text-lg tracking-widest">CAMERA TYPE</a>
                    <a href="/browse" class="text-gray-300 hover:text-white text-sm font-medium transition">Browse</a>
                    <a href="/process" class="text-gray-300 hover:text-white text-sm font-medium transition">Process</a>
                    <a href="/contact" class="text-gray-300 hover:text-white text-sm font-medium transition">Contact</a>
                </div>
                <div class="flex items-center gap-3">
                    <% if (user) { %>
                        <a href="/cart" class="text-gray-300 hover:text-white text-sm font-medium transition px-3 py-2 rounded-lg hover:bg-gray-800">🛒 Cart</a>
                        <a href="/profile" class="text-gray-300 hover:text-white text-sm font-medium transition px-3 py-2 rounded-lg hover:bg-gray-800">👤 <%= user.username %></a>
                        <% if (user.role === 'admin') { %>
                            <a href="/admin" class="bg-purple-600 hover:bg-purple-500 text-white px-4 py-2 rounded-lg text-sm font-medium transition">Admin</a>
                        <% } %>
                        <form action="/logout" method="POST" class="inline">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="bg-gray-700 hover:bg-gray-600 text-white px-4 py-2 rounded-lg text-sm font-medium transition">Logout</button>
                        </form>
                    <% } else { %>
                        <a href="/signin" class="text-gray-300 hover:text-white text-sm font-medium transition px-3 py-2">Sign In</a>
                        <a href="/signup" class="bg-yellow-400 hover:bg-yellow-300 text-black px-4 py-2 rounded-lg text-sm font-bold transition">Sign Up</a>
                    <% } %>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

        <!-- Page Header -->
        <div class="mb-8">
            <h1 class="text-3xl font-black text-gray-900">Browse Cameras</h1>
            <p class="text-gray-500 mt-1">เลือกกล้องที่คุณต้องการเช่า</p>
        </div>

        <!-- Filter Bar -->
        <form method="GET" action="/browse" class="bg-white rounded-2xl shadow-sm border border-gray-200 p-5 mb-8">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 items-end">
                <div class="lg:col-span-2">
                    <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">Search</label>
                    <input type="text" name="search" value="<%= searchQuery %>" placeholder="Brand or model..."
                        class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:border-transparent">
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">Type</label>
                    <select name="type" class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:border-transparent bg-white">
                        <option value="">All Types</option>
                        <option value="digital" <%= selectedType === 'digital' ? 'selected' : '' %>>Digital</option>
                        <option value="film" <%= selectedType === 'film' ? 'selected' : '' %>>Film</option>
                        <% if (typeof categories !== 'undefined' && categories) { %>
                            <% categories.forEach(function(cat) { %>
                                <% if (cat.name && cat.name.toLowerCase() !== 'digital' && cat.name.toLowerCase() !== 'film') { %>
                                    <option value="<%= cat.name.toLowerCase() %>" <%= selectedType === cat.name.toLowerCase() ? 'selected' : '' %>><%= cat.name %></option>
                                <% } %>
                            <% }) %>
                        <% } %>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">Min Price (฿/day)</label>
                    <input type="number" name="minPrice" value="<%= minPrice !== null ? minPrice : '' %>" min="0" placeholder="0"
                        class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:border-transparent">
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">Max Price (฿/day)</label>
                    <div class="flex gap-2">
                        <input type="number" name="maxPrice" value="<%= maxPrice !== null ? maxPrice : '' %>" min="0" placeholder="Any"
                            class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:border-transparent">
                        <button type="submit" class="bg-gray-900 hover:bg-gray-700 text-white px-5 py-2.5 rounded-lg text-sm font-semibold transition whitespace-nowrap">Filter</button>
                    </div>
                </div>
            </div>
        </form>

        <!-- Camera Grid -->
        <% if (!cameras || cameras.length === 0) { %>
            <div class="bg-white rounded-2xl border border-gray-200 p-16 text-center">
                <div class="text-6xl mb-4">📷</div>
                <h3 class="text-xl font-bold text-gray-700 mb-2">No cameras found</h3>
                <p class="text-gray-500">ลองเปลี่ยน filter หรือ <a href="/browse" class="text-yellow-600 hover:underline font-medium">ดูทั้งหมด</a></p>
            </div>
        <% } else { %>
            <div class="text-sm text-gray-500 mb-4"><%= cameras.length %> camera<%= cameras.length !== 1 ? 's' : '' %> found</div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                <% cameras.forEach(function(camera) { %>
                    <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden card-hover">
                        <div class="relative h-48 bg-gray-100 overflow-hidden">
                            <% if (camera.image) { %>
                                <img src="<%= camera.image %>" alt="<%= camera.brand %> <%= camera.model %>" class="w-full h-full object-cover">
                            <% } else { %>
                                <div class="w-full h-full flex items-center justify-center">
                                    <svg class="w-16 h-16 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                    </svg>
                                </div>
                            <% } %>
                            <div class="absolute top-3 right-3">
                                <% if (camera.status === 'available') { %>
                                    <span class="bg-green-500 text-white text-xs font-bold px-2 py-1 rounded-full">Available</span>
                                <% } else { %>
                                    <span class="bg-red-500 text-white text-xs font-bold px-2 py-1 rounded-full">Unavailable</span>
                                <% } %>
                            </div>
                        </div>
                        <div class="p-4">
                            <div class="mb-1">
                                <div class="text-xs font-semibold text-gray-400 uppercase tracking-wide"><%= camera.brand %></div>
                                <h3 class="text-base font-bold text-gray-900 truncate"><%= camera.model %></h3>
                            </div>
                            <% if (camera.categoryName) { %>
                                <span class="inline-block text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full mb-3"><%= camera.categoryName %></span>
                            <% } %>
                            <div class="flex items-center justify-between mb-4">
                                <div>
                                    <span class="text-xl font-black text-gray-900"><%= Number(camera.pricePerDay).toLocaleString() %></span>
                                    <span class="text-sm text-gray-500"> ฿/day</span>
                                </div>
                            </div>
                            <% if (camera.status === 'available') { %>
                                <% if (user) { %>
                                    <form action="/book" method="POST" class="space-y-2">
                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                        <input type="hidden" name="cameraId" value="<%= camera.id %>">
                                        <div class="grid grid-cols-2 gap-2">
                                            <div>
                                                <label class="block text-xs text-gray-500 mb-1">Start Date</label>
                                                <input type="date" name="startDate" required min="<%= new Date().toISOString().slice(0,10) %>"
                                                    class="w-full border border-gray-200 rounded-lg px-2 py-1.5 text-xs focus:outline-none focus:ring-2 focus:ring-yellow-400">
                                            </div>
                                            <div>
                                                <label class="block text-xs text-gray-500 mb-1">End Date</label>
                                                <input type="date" name="endDate" required min="<%= new Date().toISOString().slice(0,10) %>"
                                                    class="w-full border border-gray-200 rounded-lg px-2 py-1.5 text-xs focus:outline-none focus:ring-2 focus:ring-yellow-400">
                                            </div>
                                        </div>
                                        <button type="submit" class="w-full bg-gray-900 hover:bg-gray-700 text-white font-bold py-2.5 rounded-lg text-sm transition">Book Now</button>
                                    </form>
                                <% } else { %>
                                    <a href="/signin" class="block w-full text-center bg-yellow-400 hover:bg-yellow-300 text-black font-bold py-2.5 rounded-lg text-sm transition">Sign in to Book</a>
                                <% } %>
                            <% } else { %>
                                <button disabled class="w-full bg-gray-200 text-gray-400 font-bold py-2.5 rounded-lg text-sm cursor-not-allowed">Not Available</button>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </main>

</body>
</html>