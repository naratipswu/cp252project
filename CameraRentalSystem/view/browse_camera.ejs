<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Browse Cameras - Camera Rental System</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #1a150d; color: white; }
        .font-serif-elegant { font-family: 'Playfair Display', serif; }
        .bg-brand-brown { background-color: #1a150d; }
        .text-brand-yellow { color: #d69e2e; }
        .bg-brand-yellow { background-color: #d69e2e; }
        .bg-card-dark { background-color: #262119; }
        .accordion-header { border-bottom: 1px solid #444; padding-bottom: 0.5rem; margin-bottom: 1rem; }
        .sidebar-link { color: #9ca3af; font-weight: 700; transition: color 0.2s; display: block; margin-bottom: 0.75rem; }
        .sidebar-link:hover { color: #d69e2e; }
        .sidebar-link.active { color: #d69e2e; }
        .search-container { background-color: #d9d9d9; border-radius: 9999px; }
        .camera-card { background-color: #262119; border-radius: 1rem; overflow: hidden; }
        .camera-image { height: 12rem; background-color: #111; position: relative; }
        .camera-image img { width: 100%; height: 100%; object-cover: cover; }
    </style>
</head>
<body class="min-h-screen">

    <!-- Navbar -->
    <nav class="flex h-16 w-full sticky top-0 z-50 bg-brand-brown shadow-lg">
        <!-- Logo Area -->
        <a href="/" class="bg-brand-yellow text-black font-black text-lg md:text-xl flex items-center justify-center px-6 md:px-10 tracking-wider hover:opacity-90 transition">
            CAMERA TYPE
        </a>

        <!-- Navigation Links -->
        <div class="flex-1 bg-[#222] flex items-center justify-start px-8 gap-8 hidden md:flex border-b border-black">
            <a href="/browse?type=digital" class="text-white font-bold tracking-wider hover:text-brand-yellow transition">DIGITAL</a>
            <a href="/browse?type=film" class="text-white font-bold tracking-wider hover:text-brand-yellow transition">FILM</a>
            <a href="/browse?type=photo" class="text-white font-bold tracking-wider hover:text-brand-yellow transition">PHOTO</a>
            <a href="/process" class="text-white font-bold tracking-wider hover:text-brand-yellow transition">PROCESS</a>
            <a href="/contact" class="text-white font-bold tracking-wider hover:text-brand-yellow transition">CONTACT</a>
        </div>

        <!-- Icons Area -->
        <div class="bg-white text-black flex items-center justify-center px-6 gap-6 ml-auto md:ml-0 border-b border-black">
            <a href="/profile" class="hover:text-gray-600 transition" title="Profile">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                </svg>
            </a>
            <% if (user) { %>
                <form action="/logout" method="POST" class="inline">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="hover:text-red-600 transition font-semibold text-sm">Logout</button>
                </form>
            <% } %>
            <a href="/cart" class="hover:text-gray-600 transition" title="Cart">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
                </svg>
            </a>
        </div>
    </nav>

    <div class="max-w-7xl mx-auto px-6 py-12 flex flex-col md:flex-row gap-12">
        <!-- Sidebar -->
        <aside class="w-full md:w-64 flex flex-col gap-10">
            <!-- Brand Section -->
            <div>
                <div class="accordion-header flex justify-between items-center text-xl font-black">
                    <span>Brand</span>
                    <span class="text-gray-500">-</span>
                </div>
                <div class="flex flex-col">
                    <% if (typeof brands !== 'undefined') { %>
                        <% brands.forEach(brand => { %>
                            <a href="/browse?search=<%= encodeURIComponent(brand) %>" class="sidebar-link"><%= brand %></a>
                        <% }) %>
                    <% } else { %>
                        <a href="#" class="sidebar-link">Cannon</a>
                        <a href="#" class="sidebar-link">Fujifilm</a>
                        <a href="#" class="sidebar-link">Sony</a>
                        <a href="#" class="sidebar-link">Kodak</a>
                    <% } %>
                </div>
            </div>

            <!-- Category Section -->
            <div>
                <div class="accordion-header flex justify-between items-center text-xl font-black">
                    <span>Category</span>
                    <span class="text-gray-500">-</span>
                </div>
                <div class="flex flex-col">
                    <a href="/browse" class="sidebar-link <%= !selectedType ? 'active text-brand-yellow' : '' %>">All</a>
                    <% categories.forEach(cat => { %>
                        <a href="/browse?type=<%= encodeURIComponent(cat.name) %>" 
                           class="sidebar-link <%= (selectedType && selectedType.toLowerCase() === cat.name.toLowerCase()) ? 'active text-brand-yellow' : '' %>">
                            <%= cat.name %>
                        </a>
                    <% }) %>
                </div>
            </div>

            <!-- Price Section -->
            <div>
                <div class="accordion-header flex justify-between items-center text-xl font-black">
                    <span>Price</span>
                    <span class="text-gray-500">-</span>
                </div>
                <div class="flex flex-col gap-4">
                    <form action="/browse" method="GET" class="flex flex-col gap-2">
                        <% if (selectedType) { %><input type="hidden" name="type" value="<%= selectedType %>"><% } %>
                        <% if (searchQuery) { %><input type="hidden" name="search" value="<%= searchQuery %>"><% } %>
                        <input type="number" name="minPrice" value="<%= minPrice %>" placeholder="Min" class="bg-black/30 border border-gray-700 rounded px-2 py-1 text-sm focus:border-brand-yellow outline-none">
                        <input type="number" name="maxPrice" value="<%= maxPrice %>" placeholder="Max" class="bg-black/30 border border-gray-700 rounded px-2 py-1 text-sm focus:border-brand-yellow outline-none">
                        <button type="submit" class="bg-brand-yellow text-black font-bold text-xs py-2 rounded hover:opacity-90 transition">APPLY</button>
                    </form>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 flex flex-col gap-8">
            <!-- Search Bar -->
            <form action="/browse" method="GET" class="search-container flex w-full max-w-2xl ml-auto">
                <% if (selectedType) { %><input type="hidden" name="type" value="<%= selectedType %>"><% } %>
                <input type="text" name="search" value="<%= searchQuery %>" placeholder="Search products..." class="flex-1 bg-transparent px-6 py-3 text-black outline-none font-medium">
                <button type="submit" class="bg-brand-yellow px-6 flex items-center justify-center rounded-r-full hover:opacity-90 transition p-2">
                    <svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                    </svg>
                </button>
            </form>

            <!-- Grid -->
            <% if (!cameras || cameras.length === 0) { %>
                <div class="py-20 text-center">
                    <h2 class="text-2xl font-black mb-2 italic">NO CAMERAS FOUND</h2>
                    <p class="text-gray-500">Try adjusting your filters or search query.</p>
                </div>
            <% } else { %>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    <% cameras.forEach(camera => { %>
                        <div class="camera-card group">
                            <div class="camera-image">
                                <img src="<%= camera.image %>" alt="<%= camera.model %>" class="opacity-80 group-hover:opacity-100 transition duration-300">
                                <div class="absolute top-2 left-2 bg-brand-yellow text-black text-[10px] font-black px-2 py-0.5 rounded uppercase">
                                    <%= camera.status === 'available' ? 'AVAILABLE' : 'MAINTENANCE' %>
                                </div>
                            </div>
                            <div class="p-5 flex flex-col gap-2">
                                <div class="flex justify-between items-start">
                                    <div>
                                        <h3 class="text-xl font-black leading-none mb-1"><%= camera.model %></h3>
                                        <p class="text-xs text-gray-400 opacity-60 uppercase font-bold tracking-widest"><%= camera.brand %></p>
                                    </div>
                                    <div class="text-xl font-black text-brand-yellow">
                                        <%= Number(camera.pricePerDay).toLocaleString() %> ฿
                                        <span class="block text-[10px] text-gray-500 font-normal text-right">/day</span>
                                    </div>
                                </div>
                                <p class="text-[10px] text-gray-500 font-bold uppercase tracking-widest"><%= camera.categoryName %></p>
                                
                                <% if (camera.status === 'available') { %>
                                    <% if (user) { %>
                                        <form action="/book" method="POST" class="mt-4 flex flex-col gap-3">
                                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                            <input type="hidden" name="cameraId" value="<%= camera.id %>">
                                            <div class="grid grid-cols-2 gap-2">
                                                <div class="flex flex-col">
                                                    <label class="text-[9px] font-black uppercase tracking-widest text-gray-500 mb-1">Start Date</label>
                                                    <input type="date" name="startDate" required min="<%= new Date().toISOString().slice(0,10) %>"
                                                        class="bg-black/50 border border-gray-800 text-white rounded p-1 text-xs outline-none focus:border-brand-yellow">
                                                </div>
                                                <div class="flex flex-col">
                                                    <label class="text-[9px] font-black uppercase tracking-widest text-gray-500 mb-1">End Date</label>
                                                    <input type="date" name="endDate" required min="<%= new Date().toISOString().slice(0,10) %>"
                                                        class="bg-black/50 border border-gray-800 text-white rounded p-1 text-xs outline-none focus:border-brand-yellow">
                                                </div>
                                            </div>
                                            <button type="submit" class="w-full bg-brand-yellow text-black font-black py-2 rounded text-xs tracking-widest hover:bg-yellow-400 transition">BOOK NOW</button>
                                        </form>
                                    <% } else { %>
                                        <a href="/signin" class="mt-4 w-full bg-brand-yellow text-black text-center font-black py-2 rounded text-xs tracking-widest hover:bg-yellow-400 transition">SIGN IN TO BOOK</a>
                                    <% } %>
                                <% } else { %>
                                    <button disabled class="mt-4 w-full bg-gray-800 text-gray-500 font-black py-2 rounded text-xs tracking-widest cursor-not-allowed uppercase">Under Maintenance</button>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </main>
    </div>

</body>
</html>