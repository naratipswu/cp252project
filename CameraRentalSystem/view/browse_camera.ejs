<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Browse Cameras - Camera Rental System</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;900&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@400;700;900&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/themes/dark.css">
    <style>
        :root {
            --brand-brown-dark: #120e09;
            --brand-brown: #1a150d;
            --brand-yellow: #d69e2e;
            --brand-yellow-light: #eab308;
            --card-bg: #221c14;
            --card-hover: #2d251a;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--brand-brown-dark);
            color: #ffffff;
            -webkit-font-smoothing: antialiased;
        }

        .font-serif-elegant {
            font-family: 'Playfair Display', serif;
        }

        ::-webkit-scrollbar {
            width: 8px;
        }

        ::-webkit-scrollbar-track {
            background: var(--brand-brown-dark);
        }

        ::-webkit-scrollbar-thumb {
            background: #333;
            border-radius: 10px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--brand-yellow);
        }

        .nav-link {
            font-family: 'Inter', sans-serif;
            color: #ffffff;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            transition: all 0.3s ease;
        }

        .nav-link:hover {
            color: var(--brand-yellow);
        }

        .nav-link.active {
            color: var(--brand-yellow);
        }

        .bg-brand-yellow {
            background-color: var(--brand-yellow);
        }

        .text-brand-yellow {
            color: var(--brand-yellow);
        }

        .sidebar-header {
            position: relative;
            padding-bottom: 0.75rem;
            margin-bottom: 1.5rem;
        }

        .sidebar-header::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 30px;
            height: 2px;
            background: var(--brand-yellow);
        }

        .sidebar-link {
            color: #9ca3af;
            font-weight: 500;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 0;
        }

        .sidebar-link:hover {
            color: var(--brand-yellow);
            transform: translateX(4px);
        }

        .sidebar-link.active {
            color: var(--brand-yellow);
            font-weight: 700;
        }

        .search-container {
            background: rgba(255, 255, 255, 0.07);
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.3s ease;
        }

        .search-container:focus-within {
            background: rgba(255, 255, 255, 0.12);
            border-color: var(--brand-yellow);
            box-shadow: 0 0 0 4px rgba(214, 158, 46, 0.1);
        }

        .camera-card {
            background-color: var(--card-bg);
            border-radius: 1.25rem;
            overflow: hidden;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            border: 1px solid rgba(255, 255, 255, 0.03);
            display: flex;
            flex-direction: column;
        }

        .camera-card:hover {
            transform: translateY(-8px);
            background-color: var(--card-hover);
            border-color: rgba(214, 158, 46, 0.3);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
        }

        .camera-image-container {
            height: 14rem;
            background-color: #000;
            position: relative;
            overflow: hidden;
        }

        .camera-image-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .camera-card:hover .camera-image-container img {
            transform: scale(1.08);
        }

        .status-badge {
            backdrop-filter: blur(4px);
            background: rgba(0, 0, 0, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .date-input {
            background: rgba(0, 0, 0, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.15);
            transition: all 0.3s ease;
            font-weight: 600;
        }

        .date-input:focus {
            border-color: var(--brand-yellow);
            background: rgba(0, 0, 0, 0.6);
        }

        .btn-primary {
            background: var(--brand-yellow);
            color: #000;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            font-weight: 800;
        }

        .btn-primary:hover {
            background: var(--brand-yellow-light);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(214, 158, 46, 0.2);
        }

        .btn-primary:active {
            transform: translateY(0);
        }

        .animate-card {
            animation: fadeIn 0.6s ease-out forwards;
        }

        .admin-panel {
            background: linear-gradient(135deg, rgba(214, 158, 46, 0.1) 0%, rgba(0, 0, 0, 0) 100%);
            border: 1px solid rgba(214, 158, 46, 0.2);
            backdrop-filter: blur(10px);
        }

        .admin-input {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: white;
            transition: all 0.3s ease;
        }

        .admin-input:focus {
            border-color: var(--brand-yellow);
            background: rgba(255, 255, 255, 0.08);
            outline: none;
        }

        .flatpickr-calendar {
            background: #1a150d !important;
            border: 1px solid #d69e2e !important;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.5) !important;
        }

        .flatpickr-day.flatpickr-disabled,
        .flatpickr-day.flatpickr-disabled:hover {
            background: #4b0000 !important;
            color: #ff9999 !important;
            cursor: not-allowed !important;
            opacity: 0.5;
        }

        .flatpickr-day.selected {
            background: #d69e2e !important;
            border-color: #d69e2e !important;
        }

        .flatpickr-months .flatpickr-month,
        .flatpickr-current-month .flatpickr-monthDropdown-months {
            background: #1a150d !important;
        }

        .flatpickr-weekday {
            color: #d69e2e !important;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>

<body class="min-h-screen">

    <!-- Navbar -->
    <nav class="flex h-16 w-full sticky top-0 z-50 border-b border-white/10 bg-brand-brown font-[Inter]">
        <!-- Logo Area -->
        <a href="/"
            class="bg-brand-yellow text-black font-black text-lg md:text-xl flex items-center justify-center px-6 md:px-10 tracking-wider hover:bg-yellow-500 transition-colors duration-300">
            CAMERA TYPE
        </a>

        <!-- Navigation Links -->
        <div class="flex-1 bg-[#222] flex items-center justify-start px-8 gap-8 hidden md:flex">
            <% const currentPath = typeof path !== 'undefined' ? path : ''; %>
            <a href="/browse?type=digital"
                class="nav-link <%= selectedType === 'digital' ? 'active' : '' %>">Digital</a>
            <a href="/browse?type=film"
                class="nav-link <%= selectedType === 'film' ? 'active' : '' %>">Film</a>
            <a href="/process"
                class="nav-link">Process</a>
            <a href="/contact"
                class="nav-link">Contact</a>
        </div>

        <!-- Icons Area -->
        <div class="bg-white text-black flex items-center justify-center px-6 gap-6 ml-auto md:ml-0">
            <a href="<%= user ? '/profile' : '/signin' %>" class="hover:text-gray-600 transition-colors duration-300" title="<%= user ? 'Profile' : 'Sign in' %>">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                </svg>
            </a>
            <% if (user) { %>
                <form action="/logout" method="POST" class="inline">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit"
                        class="text-xs font-black tracking-widest uppercase hover:text-red-600 transition-colors">Logout</button>
                </form>
            <% } %>
            <a href="/cart" class="hover:text-gray-600 transition-colors duration-300" title="Cart">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z">
                    </path>
                </svg>
            </a>
        </div>
    </nav>

    <div class="max-w-7xl mx-auto px-6 py-16 flex flex-col lg:flex-row gap-16">

        <!-- Sidebar -->
        <aside class="w-full lg:w-64 flex flex-col gap-12">

            <!-- Brand Section -->
            <div>
                <h3 class="sidebar-header text-sm font-black uppercase tracking-[0.2em] text-white">Brand</h3>
                <div class="flex flex-col gap-2">
                    <% if (typeof brands !=='undefined' ) { %>
                        <% brands.forEach(brand=> { %>
                            <a href="/browse?search=<%= encodeURIComponent(brand) %>" class="sidebar-link group">
                                <span
                                    class="w-1.5 h-1.5 rounded-full bg-transparent group-hover:bg-brand-yellow transition-all"></span>
                                <%= brand %>
                            </a>
                            <% }) %>
                                <% } %>
                </div>
            </div>

            <!-- Category Section -->
            <div>
                <h3 class="sidebar-header text-sm font-black uppercase tracking-[0.2em] text-white">Category</h3>
                <div class="flex flex-col gap-2">
                    <a href="/browse" class="sidebar-link group <% if (!selectedType) { %>active<% } %>">
                        <span
                            class="w-1.5 h-1.5 rounded-full <% if (!selectedType) { %>bg-brand-yellow<% } else { %>bg-transparent<% } %> group-hover:bg-brand-yellow transition-all"></span>
                        All Products
                    </a>
                    <% categories.forEach(cat=> { %>
                        <a href="/browse?type=<%= encodeURIComponent(cat.name) %>"
                            class="sidebar-link group <% if (selectedType && selectedType.toLowerCase() === cat.name.toLowerCase()) { %>active<% } %>">
                            <span
                                class="w-1.5 h-1.5 rounded-full <% if (selectedType && selectedType.toLowerCase() === cat.name.toLowerCase()) { %>bg-brand-yellow<% } else { %>bg-transparent<% } %> group-hover:bg-brand-yellow transition-all"></span>
                            <%= cat.name %>
                        </a>
                        <% }) %>
                </div>
            </div>

            <!-- Price Section -->
            <div>
                <h3 class="sidebar-header text-sm font-black uppercase tracking-[0.2em] text-white">Price Range</h3>
                <form action="/browse" method="GET" class="flex flex-col gap-4">
                    <% if (selectedType) { %>
                        <input type="hidden" name="type" value="<%= selectedType %>">
                        <% } %>
                            <% if (searchQuery) { %>
                                <input type="hidden" name="search" value="<%= searchQuery %>">
                                <% } %>
                                    <div class="flex flex-col gap-3">
                                        <div class="relative">
                                            <span
                                                class="absolute left-3 top-1/2 -translate-y-1/2 text-[10px] text-gray-500 font-bold">MIN</span>
                                            <input type="number" name="minPrice" value="<%= minPrice %>" placeholder="0"
                                                class="w-full bg-white/5 border border-white/10 rounded-xl pl-10 pr-4 py-2.5 text-sm focus:border-brand-yellow outline-none transition-all">
                                        </div>
                                        <div class="relative">
                                            <span
                                                class="absolute left-3 top-1/2 -translate-y-1/2 text-[10px] text-gray-500 font-bold">MAX</span>
                                            <input type="number" name="maxPrice" value="<%= maxPrice %>" placeholder="∞"
                                                class="w-full bg-white/5 border border-white/10 rounded-xl pl-10 pr-4 py-2.5 text-sm focus:border-brand-yellow outline-none transition-all">
                                        </div>
                                    </div>
                                    <button type="submit"
                                        class="btn-primary w-full text-[10px] font-black tracking-[0.2em] py-3 rounded-xl uppercase">Apply
                                        Filters</button>
                </form>
            </div>

        </aside>

        <!-- Main Content -->
        <main class="flex-1 flex flex-col gap-12">

            <!-- Header Row -->
            <div class="flex flex-col md:flex-row justify-between items-end gap-6">
                <div>
                    <% const displayCount=(cameras && cameras.length) || 0; %>
                        <h2 class="text-5xl font-black tracking-tighter text-white mb-3 uppercase">Explore Gear</h2>
                        <p class="text-gray-300 text-base font-semibold">Showing <%= displayCount %> premium cameras
                                available for rent.</p>
                </div>

                <!-- Search Bar -->
                <form action="/browse" method="GET"
                    class="search-container flex w-full md:w-[400px] rounded-2xl overflow-hidden">
                    <% if (selectedType) { %>
                        <input type="hidden" name="type" value="<%= selectedType %>">
                        <% } %>
                            <input type="text" name="search" value="<%= searchQuery %>"
                                placeholder="Search by model or brand..."
                                class="flex-1 bg-transparent px-6 py-4 text-white text-sm outline-none placeholder:text-gray-600 font-medium">
                            <button type="submit"
                                class="px-6 flex items-center justify-center hover:text-brand-yellow transition-colors">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                                </svg>
                            </button>
                </form>
            </div>

            <!-- Admin Add Panel -->
            <% if (user && user.role==='admin' ) { %>
                <div class="w-full flex justify-end">
                    <button onclick="toggleAdminPanel()"
                        class="flex items-center gap-2 bg-brand-yellow/10 hover:bg-brand-yellow/20 border border-brand-yellow/30 text-brand-yellow px-6 py-3 rounded-xl text-xs font-black tracking-widest transition-all uppercase">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4">
                            </path>
                        </svg>
                        Add New Equipment
                    </button>
                </div>

                <div id="adminAddPanel" class="hidden animate-card">
                    <div class="admin-panel rounded-3xl p-8 lg:p-10">
                        <div class="flex justify-between items-center mb-8 pb-4 border-b border-white/5">
                            <h3 class="text-xl font-black text-white uppercase tracking-wider">Product Information</h3>
                            <button onclick="toggleAdminPanel()"
                                class="text-gray-500 hover:text-white transition-colors">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M6 18L18 6M6 6l12 12"></path>
                                </svg>
                            </button>
                        </div>

                        <form action="/admin/cameras" method="POST" enctype="multipart/form-data"
                            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                            <div class="flex flex-col gap-2">
                                <label
                                    class="text-[11px] font-black uppercase tracking-widest text-brand-yellow">Brand</label>
                                <input type="text" name="brand" required placeholder="Sony, Canon, Nikon..."
                                    class="admin-input rounded-xl px-4 py-3.5 text-sm">
                            </div>

                            <div class="flex flex-col gap-2">
                                <label class="text-[11px] font-black uppercase tracking-widest text-brand-yellow">Model
                                    Name</label>
                                <input type="text" name="model" required placeholder="A7III, EOS R5..."
                                    class="admin-input rounded-xl px-4 py-3.5 text-sm">
                            </div>

                            <div class="flex flex-col gap-2">
                                <label
                                    class="text-[11px] font-black uppercase tracking-widest text-brand-yellow">Category</label>
                                <select name="categoryId" required
                                    class="admin-input rounded-xl px-4 py-[14px] text-sm appearance-none bg-brand-brown">
                                    <% categories.forEach(cat=> { %>
                                        <option value="<%= cat.id %>">
                                            <%= cat.name %>
                                        </option>
                                        <% }) %>
                                </select>
                            </div>

                            <div class="flex flex-col gap-2">
                                <label class="text-[11px] font-black uppercase tracking-widest text-brand-yellow">Price
                                    Per Day (฿)</label>
                                <input type="number" name="pricePerDay" required placeholder="800" min="1"
                                    class="admin-input rounded-xl px-4 py-3.5 text-sm">
                            </div>

                            <div class="flex flex-col gap-2">
                                <label class="text-[11px] font-black uppercase tracking-widest text-brand-yellow">Stock
                                    Quantity</label>
                                <input type="number" name="stock" required placeholder="5" min="1"
                                    class="admin-input rounded-xl px-4 py-3.5 text-sm">
                            </div>

                            <div class="flex flex-col gap-2">
                                <label
                                    class="text-[11px] font-black uppercase tracking-widest text-brand-yellow">Equipment
                                    Image</label>
                                <input type="file" name="imageFile"
                                    class="admin-input rounded-xl px-4 py-[9px] text-xs file:hidden cursor-pointer">
                            </div>

                            <div class="lg:col-span-3 flex justify-end gap-4 mt-4">
                                <button type="button" onclick="toggleAdminPanel()"
                                    class="text-gray-400 hover:text-white px-8 py-3 rounded-xl text-xs font-black uppercase tracking-widest transition-colors">Cancel</button>
                                <button type="submit"
                                    class="bg-brand-yellow text-black px-10 py-4 rounded-xl text-xs font-black uppercase tracking-[0.2em] hover:bg-yellow-500 transition-all shadow-lg shadow-brand-yellow/20">Add
                                    Product Now</button>
                            </div>
                        </form>
                    </div>
                </div>
                <% } %>

                    <!-- Grid -->
                    <% if (!cameras || cameras.length===0) { %>
                        <div
                            class="py-32 flex flex-col items-center justify-center border-2 border-dashed border-white/5 rounded-3xl">
                            <div class="w-20 h-20 bg-white/5 rounded-full flex items-center justify-center mb-6">
                                <svg class="w-10 h-10 text-gray-700" fill="none" stroke="currentColor"
                                    viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                        d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z">
                                    </path>
                                </svg>
                            </div>
                            <h2 class="text-xl font-black text-white italic tracking-wider mb-2">NO GEAR FOUND</h2>
                            <p class="text-gray-500 text-sm">We couldn't find matching items. Try clearing filters.</p>
                            <a href="/browse"
                                class="mt-8 text-brand-yellow text-xs font-black tracking-widest uppercase border-b border-brand-yellow/30 pb-1 hover:border-brand-yellow transition-all">Show
                                all cameras</a>
                        </div>
                        <% } else { %>
                            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-10">
                                <% cameras.forEach((camera, index)=> { %>
                                    <% const delay=index * 0.1; %>
                                        <div class="camera-card group animate-card"
                                            style="animation-delay: <%= delay %>s">
                                            <div class="camera-image-container">
                                                <img src="<%= camera.image %>" alt="<%= camera.model %>" loading="lazy">
                                                <div class="absolute top-4 left-4 flex gap-2">
                                                    <div
                                                        class="status-badge text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-widest <% if (camera.availableCount > 0) { %>text-green-400<% } else { %>text-orange-400<% } %>">
                                                        <% if (camera.availableCount> 0) { %>Available<% } else { %>Out
                                                                of Stock<% } %>
                                                    </div>
                                                    <% if (camera.availableCount> 0) { %>
                                                        <div
                                                            class="status-badge text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-widest text-brand-yellow">
                                                            เหลืออีก <%= camera.availableCount %> ตัว
                                                        </div>
                                                        <% } %>
                                                </div>
                                            </div>

                                            <div class="p-8 flex flex-col flex-1">
                                                <div class="flex justify-between items-start mb-6">
                                                    <div class="max-w-[65%]">
                                                        <p
                                                            class="text-[12px] text-brand-yellow font-black uppercase tracking-[0.2em] mb-1">
                                                            <%= camera.brand %>
                                                        </p>
                                                        <h3 class="text-2xl font-black leading-tight text-white group-hover:text-brand-yellow transition-colors truncate"
                                                            title="<%= camera.model %>">
                                                            <%= camera.model %>
                                                        </h3>
                                                    </div>
                                                    <div class="text-right">
                                                        <% const formattedPrice=Number(camera.pricePerDay ||
                                                            0).toLocaleString(); %>
                                                            <span class="block text-2xl font-black text-white">
                                                                <%= formattedPrice %><span
                                                                        class="text-sm text-brand-yellow ml-1">฿</span>
                                                            </span>
                                                            <span
                                                                class="text-[11px] text-gray-300 font-black uppercase tracking-widest">per
                                                                day</span>
                                                    </div>
                                                </div>

                                                <div class="flex items-center gap-2 mb-8">
                                                    <div class="w-8 h-[1px] bg-brand-yellow/30"></div>
                                                    <span
                                                        class="text-[12px] text-white font-bold uppercase tracking-[0.15em]">
                                                        <%= camera.categoryName %>
                                                    </span>
                                                </div>

                                                <div class="mt-auto">
                                                    <% if (camera.status==='available' ) { %>
                                                        <% if (user) { %>
                                                            <form action="/book" method="POST"
                                                                class="flex flex-col gap-4">
                                                                <input type="hidden" name="_csrf"
                                                                    value="<%= csrfToken %>">
                                                                <input type="hidden" name="cameraId"
                                                                    value="<%= camera.id %>">
                                                                <div class="grid grid-cols-2 gap-3">
                                                                    <div class="flex flex-col gap-1.5">
                                                                        <label
                                                                            class="text-[11px] font-black uppercase tracking-widest text-brand-yellow">Pick
                                                                            Up</label>
                                                                        <input type="text" name="startDate" required
                                                                            placeholder="Select date"
                                                                            data-camera-id="<%= camera.id %>"
                                                                            class="date-picker-start date-input w-full text-white rounded-xl px-3 py-3 text-sm outline-none cursor-pointer">
                                                                    </div>
                                                                    <div class="flex flex-col gap-1.5">
                                                                        <label
                                                                            class="text-[11px] font-black uppercase tracking-widest text-brand-yellow">Return</label>
                                                                        <input type="text" name="endDate" required
                                                                            placeholder="Select date"
                                                                            data-camera-id="<%= camera.id %>"
                                                                            class="date-picker-end date-input w-full text-white rounded-xl px-3 py-3 text-sm outline-none cursor-pointer">
                                                                    </div>
                                                                </div>
                                                                <button type="submit"
                                                                    class="btn-primary w-full font-black py-5 rounded-xl text-sm tracking-[0.2em] uppercase">Reserve
                                                                    Now</button>
                                                            </form>
                                                            <% } else { %>
                                                                <a href="/signin"
                                                                    class="btn-primary block w-full text-center font-black py-4 rounded-xl text-xs tracking-[0.2em] uppercase">Sign
                                                                    in to book</a>
                                                                <% } %>
                                                                    <% } else { %>
                                                                        <button disabled
                                                                            class="w-full bg-white/5 text-gray-600 font-black py-4 rounded-xl text-xs tracking-[0.2em] cursor-not-allowed uppercase border border-white/5">Under
                                                                            Maintenance</button>
                                                                        <% } %>
                                                </div>
                                            </div>
                                        </div>
                                        <% }) %>
                            </div>
                            <% } %>

        </main>
    </div>

    <!-- Footer Simple -->
    <footer
        class="max-w-7xl mx-auto px-6 py-12 border-t border-white/5 mt-12 flex flex-col md:flex-row justify-between items-center gap-6">
        <p class="text-gray-600 text-[10px] font-semibold uppercase tracking-[0.2em]">© 2024 Camera Type Rental. All
            rights reserved.</p>
        <div class="flex gap-8">
            <a href="#"
                class="text-gray-600 hover:text-brand-yellow text-[10px] font-semibold uppercase tracking-[0.2em] transition-colors">Privacy</a>
            <a href="#"
                class="text-gray-600 hover:text-brand-yellow text-[10px] font-semibold uppercase tracking-[0.2em] transition-colors">Terms</a>
            <a href="/contact"
                class="text-gray-600 hover:text-brand-yellow text-[10px] font-semibold uppercase tracking-[0.2em] transition-colors">Support</a>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const startInputs = document.querySelectorAll('.date-picker-start');
            const endInputs = document.querySelectorAll('.date-picker-end');

            const maxDate = new Date();
            maxDate.setDate(maxDate.getDate() + 30);

            async function getBookedDates(cameraId) {
                try {
                    const response = await fetch(`/api/cameras/${cameraId}/booked-dates`);
                    if (!response.ok) return [];
                    const data = await response.json();
                    return data.map(range => ({ from: range.from, to: range.to }));
                } catch (error) {
                    console.error('Error fetching booked dates:', error);
                    return [];
                }
            }

            startInputs.forEach(async (startInput, index) => {
                const cameraId = startInput.dataset.cameraId;
                const endInput = endInputs[index];
                const bookedDates = await getBookedDates(cameraId);

                const startInstance = flatpickr(startInput, {
                    minDate: "today",
                    maxDate: maxDate,
                    disable: bookedDates,
                    dateFormat: "Y-m-d",
                    onChange: function (selectedDates, dateStr) {
                        endInstance.set('minDate', dateStr);
                    }
                });

                const endInstance = flatpickr(endInput, {
                    minDate: "today",
                    maxDate: maxDate,
                    disable: bookedDates,
                    dateFormat: "Y-m-d",
                    onChange: function (selectedDates, dateStr) {
                        if (selectedDates.length > 0) {
                            startInstance.set('maxDate', dateStr < maxDate.toISOString() ? dateStr : maxDate);
                        }
                    }
                });
            });
        });

        function toggleAdminPanel() {
            const panel = document.getElementById('adminAddPanel');
            if (panel.classList.contains('hidden')) {
                panel.classList.remove('hidden');
                setTimeout(() => {
                    window.scrollTo({ top: panel.offsetTop - 100, behavior: 'smooth' });
                }, 50);
            } else {
                panel.classList.add('hidden');
            }
        }
    </script>
</body>

</html>