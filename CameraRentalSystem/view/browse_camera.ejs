<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Browse Cameras</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
    <!-- Flatpickr -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link rel="stylesheet" type="text/css" href="https://npmcdn.com/flatpickr/dist/themes/dark.css">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        .bg-brand-brown {
            background-color: #1a150d;
        }

        .text-brand-yellow {
            color: #d69e2e;
        }

        .bg-brand-yellow {
            background-color: #d69e2e;
        }

        .bg-card-dark {
            background-color: #262119;
        }

        .bg-sidebar-dark {
            background-color: #1a150d;
        }

        input[type="date"]::-webkit-calendar-picker-indicator {
            filter: invert(1);
            opacity: 1;
            cursor: pointer;
        }

        /* Booked dates highlighting */
        .flatpickr-day.booked {
            background: #ef4444 !important; /* Tailwind red-500 */
            border-color: #ef4444 !important;
            color: white !important;
            cursor: not-allowed !important;
        }
        
        .flatpickr-calendar {
            background: #262119 !important;
            border: 1px solid #4b5563 !important;
        }

        .flatpickr-day {
            color: #d1d5db !important;
        }

        .flatpickr-day:hover {
            background: #374151 !important;
        }

        .flatpickr-day.selected {
            background: #d69e2e !important;
            border-color: #d69e2e !important;
        }
    </style>
    <script>
        function toDateOnlyString(dateObj) {
            const y = dateObj.getFullYear();
            const m = String(dateObj.getMonth() + 1).padStart(2, '0');
            const d = String(dateObj.getDate()).padStart(2, '0');
            return `${y}-${m}-${d}`;
        }

        const flatpickrInstances = {};

        async function fetchBookedDates(cameraId) {
            try {
                const response = await fetch(`/api/cameras/${cameraId}/booked-dates`);
                return await response.json();
            } catch (err) {
                console.error('Failed to fetch booked dates', err);
                return [];
            }
        }

        async function initializeBookingInputs() {
            const today = new Date();
            today.setHours(0,0,0,0);
            const todayStr = toDateOnlyString(today);

            const maxDate = new Date();
            maxDate.setMonth(maxDate.getMonth() + 3);
            
            const dateInputs = document.querySelectorAll('.date-picker');
            
            for (const input of dateInputs) {
                const cameraId = input.id.split('-')[1];
                const isStart = input.id.startsWith('start-');
                
                const bookedRanges = await fetchBookedDates(cameraId);
                
                const fp = flatpickr(input, {
                    minDate: "today",
                    maxDate: maxDate,
                    dateFormat: "Y-m-d",
                    disable: bookedRanges,
                    onDayCreate: (dObj, dStr, fp, dayElem) => {
                        const currentStr = toDateOnlyString(dayElem.dateObj);
                        const isBooked = bookedRanges.some(range => {
                            return currentStr >= range.from && currentStr <= range.to;
                        });
                        if (isBooked) {
                            dayElem.classList.add('booked');
                        }
                    },
                    onChange: (selectedDates, dateStr, instance) => {
                        calculatePrice(cameraId, input.dataset.price);
                        
                        // If start date changed, update end date min
                        if (isStart) {
                            const endInput = document.getElementById('end-' + cameraId);
                            if (endInput && endInput._flatpickr) {
                                endInput._flatpickr.set('minDate', dateStr);
                            }
                        }
                    }
                });
                
                if (!flatpickrInstances[cameraId]) flatpickrInstances[cameraId] = {};
                flatpickrInstances[cameraId][isStart ? 'start' : 'end'] = fp;
            }
        }

        function showAvailability(cameraId) {
            const startInput = document.getElementById('start-' + cameraId);
            if (startInput && startInput._flatpickr) {
                startInput._flatpickr.open();
            }
        }

        /**
         * Calculate total price for a camera
         * @param {string | number} cameraId
         * @param {number} pricePerDay
         */
        function calculatePrice(cameraId, pricePerDay) {
            /** @type {HTMLInputElement | null} */
            const startInput = document.getElementById('start-' + cameraId);
            /** @type {HTMLInputElement | null} */
            const endInput = document.getElementById('end-' + cameraId);
            const totalSpan = document.getElementById('total-' + cameraId);
            /** @type {HTMLInputElement | null} */
            const bookBtn = document.getElementById('btn-' + cameraId);
            const statusText = document.getElementById('status-' + cameraId);
            const daysText = document.getElementById('days-' + cameraId);

            if (startInput && endInput && totalSpan && bookBtn && statusText && daysText) {
                if (startInput.value && endInput.value) {
                    const start = new Date(startInput.value);
                    const end = new Date(endInput.value);

                    start.setHours(0, 0, 0, 0);
                    end.setHours(0, 0, 0, 0);

                    if (start <= end) {
                        const diffTime = Math.abs(end.getTime() - start.getTime());
                        const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24)) + 1;

                        const total = diffDays * pricePerDay;
                        totalSpan.innerText = total.toLocaleString() + ' ฿';
                        daysText.innerText = diffDays + ' day(s)';
                        statusText.innerText = 'Ready to book';
                        statusText.className = 'text-xs text-green-400';
                        bookBtn.innerText = 'Book Now';
                        bookBtn.disabled = false;
                        bookBtn.classList.remove('opacity-50', 'cursor-not-allowed');
                        bookBtn.classList.add('hover:bg-yellow-500');
                    } else {
                        totalSpan.innerText = '0 ฿';
                        daysText.innerText = '-';
                        statusText.innerText = 'End date must be the same or after start date';
                        statusText.className = 'text-xs text-red-400';
                        bookBtn.innerText = 'Select valid dates';
                        bookBtn.disabled = true;
                        bookBtn.classList.add('opacity-50', 'cursor-not-allowed');
                        bookBtn.classList.remove('hover:bg-yellow-500');
                    }
                } else {
                    totalSpan.innerText = '0 ฿';
                    daysText.innerText = '-';
                    statusText.innerText = 'Choose start and end date';
                    statusText.className = 'text-xs text-gray-400';
                    bookBtn.innerText = 'Pick dates first';
                    bookBtn.disabled = true;
                    bookBtn.classList.add('opacity-50', 'cursor-not-allowed');
                    bookBtn.classList.remove('hover:bg-yellow-500');
                }
            }
        }

        /**
         * Simple accordion toggle for sidebar
         * @param {string} id
         */
        function toggleAccordion(id) {
            const el = document.getElementById(id);
            const icon = document.getElementById('icon-' + id);
            if (el && icon) {
                if (el.classList.contains('hidden')) {
                    el.classList.remove('hidden');
                    icon.innerText = '-';
                } else {
                    el.classList.add('hidden');
                    icon.innerText = '+';
                }
            }
        }

        function toggleAdminAddPanel() {
            const panel = document.getElementById('admin-add-panel');
            const icon = document.getElementById('admin-add-icon');
            const buttonText = document.getElementById('admin-add-button-text');
            if (!panel || !icon || !buttonText) return;

            const isHidden = panel.classList.contains('hidden');
            if (isHidden) {
                panel.classList.remove('hidden');
                icon.innerText = '-';
                buttonText.innerText = 'Hide Add Product';
            } else {
                panel.classList.add('hidden');
                icon.innerText = '+';
                buttonText.innerText = 'Add New Product';
            }
        }

        window.addEventListener('DOMContentLoaded', () => {
            initializeBookingInputs();
        });
    </script>
</head>

<body class="bg-brand-brown text-white min-h-screen">

    <!-- Navbar (Same as main page) -->
    <nav class="flex h-16 w-full sticky top-0 z-50 shadow-md bg-brand-brown">
        <!-- Logo Area -->
        <a href="/welcome"
            class="bg-brand-yellow text-black font-black text-lg md:text-xl flex items-center justify-center px-6 md:px-10 tracking-wider hover:opacity-90">
            CAMERA TYPE
        </a>

        <!-- Navigation Links -->
        <div class="flex-1 bg-[#222] flex items-center justify-start px-8 gap-8 hidden md:flex border-b border-black">
            <a href="/browse?type=digital" class="text-white font-bold tracking-wider hover:text-brand-yellow transition">DIGITAL</a>
            <a href="/browse?type=film" class="text-white font-bold tracking-wider hover:text-brand-yellow transition">FILM</a>
            <a href="#" class="text-white font-bold tracking-wider hover:text-brand-yellow transition">PHOTO</a>
            <a href="#" class="text-white font-bold tracking-wider hover:text-brand-yellow transition">PROCESS</a>
            <a href="#" class="text-white font-bold tracking-wider hover:text-brand-yellow transition">CONTACT</a>
        </div>

        <!-- Icons Area -->
        <div class="bg-white text-black flex items-center justify-center px-6 gap-6 ml-auto md:ml-0">
            <a href="/profile" class="hover:text-gray-600 transition" title="Profile">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                </svg>
            </a>
            <form action="/logout" method="POST" class="inline" title="Logout">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="hover:text-red-600 transition font-semibold text-sm">Logout</button>
            </form>
            <a href="/cart" class="hover:text-gray-600 transition" title="Cart">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z">
                    </path>
                </svg>
            </a>
        </div>
    </nav>

    <!-- Main Content Area -->
    <div class="max-w-7xl mx-auto px-6 pb-12 flex flex-col md:flex-row gap-10">
        
        <!-- Error Alert -->
        <script>
            window.addEventListener('DOMContentLoaded', () => {
                const urlParams = new URLSearchParams(window.location.search);
                const error = urlParams.get('error');
                if (error) {
                    const alertDiv = document.createElement('div');
                    alertDiv.className = 'fixed top-20 left-1/2 -translate-x-1/2 z-[100] w-full max-w-lg px-4';
                    alertDiv.innerHTML = `
                        <div class="bg-red-500 text-white px-6 py-4 rounded-xl shadow-2xl flex items-center justify-between animate-bounce">
                            <div class="flex items-center gap-3">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                <span class="font-bold">${decodeURIComponent(error)}</span>
                            </div>
                            <button onclick="this.parentElement.parentElement.remove()" class="hover:opacity-75 font-black text-xl leading-none">&times;</button>
                        </div>
                    `;
                    document.body.appendChild(alertDiv);
                    // Remove error from URL without refreshing
                    const newUrl = window.location.pathname + window.location.search.replace(/[?&]error=[^&]+/, '').replace(/^&/, '?');
                    window.history.replaceState({}, '', newUrl);
                    
                    // Auto remove after 5s
                    setTimeout(() => alertDiv.remove(), 5000);
                }
            });
        </script>

        <!-- Sidebar filters -->
        <aside class="w-full md:w-1/4 flex flex-col gap-6">

            <!-- Brand Accordion -->
            <div>
                <button onclick="toggleAccordion('brand-list')"
                    class="w-full flex items-center justify-between text-xl font-black mb-3 border-b border-gray-500 pb-1 hover:text-brand-yellow transition">
                    Brand <span id="icon-brand-list" class="font-normal text-gray-400">-</span>
                </button>
                <div id="brand-list" class="flex flex-col gap-3 pl-2 text-gray-300 font-bold tracking-wide">
                    <a href="?search=canon" class="hover:text-white transition">Cannon</a>
                    <a href="?search=fujifilm" class="hover:text-white transition">Fujifilm</a>
                    <a href="?search=sony" class="hover:text-white transition">Sony</a>
                    <a href="?search=kodak" class="hover:text-white transition">Kodak</a>
                </div>
            </div>

            <!-- Category Accordion -->
            <div>
                <button onclick="toggleAccordion('cat-list')"
                    class="w-full flex items-center justify-between text-xl font-black mb-3 border-b border-gray-500 pb-1 hover:text-brand-yellow transition mt-4">
                    Category <span id="icon-cat-list" class="font-normal text-gray-400">-</span>
                </button>
                <div id="cat-list" class="flex flex-col gap-3 pl-2 text-gray-300 font-bold tracking-wide">
                    <a href="/browse" class="<%= !selectedType ? 'text-white' : 'hover:text-white transition' %>">All</a>
                    <% categories.forEach(cat => { %>
                        <a href="?type=<%= encodeURIComponent(cat.name) %>" class="<%= selectedType === cat.name.toLowerCase() ? 'text-brand-yellow' : 'hover:text-white transition' %>"><%= cat.name %></a>
                    <% }) %>
                </div>
            </div>

            <!-- Price Accordion (Mimicking Figma text layout) -->
            <div>
                <button onclick="toggleAccordion('price-list')"
                    class="w-full flex items-center justify-between text-xl font-black mb-3 border-b border-gray-500 pb-1 hover:text-brand-yellow transition mt-4">
                    Price <span id="icon-price-list" class="font-normal text-gray-400">-</span>
                </button>
                <div id="price-list" class="flex flex-col gap-3 pl-2 text-gray-300 font-bold tracking-wide">
                    <a href="#" class="hover:text-white transition">Cannon</a>
                    <a href="#" class="hover:text-white transition">Fujifilm</a>
                    <a href="#" class="hover:text-white transition">Sony</a>
                    <a href="#" class="hover:text-white transition">Kodak</a>
                </div>
            </div>

        </aside>

        <!-- Product Grid & Search -->
        <main class="w-full md:w-3/4 flex flex-col gap-8">
            <% if (user && user.role === 'admin') { %>
                <section class="bg-gradient-to-r from-[#1f1811] to-[#2a2017] border border-yellow-800/70 rounded-2xl p-4 shadow-lg">
                    <button
                        type="button"
                        onclick="toggleAdminAddPanel()"
                        class="w-full flex items-center justify-between px-3 py-2 rounded-xl bg-black/25 hover:bg-black/35 transition">
                        <div class="flex items-center gap-2">
                            <span class="text-brand-yellow font-semibold text-sm uppercase tracking-wider">Admin Tools</span>
                            <span class="text-white font-bold" id="admin-add-button-text">Add New Product</span>
                        </div>
                        <span id="admin-add-icon" class="text-brand-yellow text-xl leading-none">+</span>
                    </button>

                    <div id="admin-add-panel" class="hidden mt-4">
                        <form action="/admin/cameras" method="POST" enctype="multipart/form-data" class="grid grid-cols-1 md:grid-cols-2 gap-3">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <div class="flex flex-col gap-2 relative">
                                <select name="brand" onchange="document.getElementById('customBrandWrapper').classList.toggle('hidden', this.value !== 'Etc')" class="px-3 py-2.5 rounded-lg bg-white text-black border border-gray-300 focus:outline-none focus:ring-2 focus:ring-yellow-500" required>
                                    <option value="" disabled selected>Select Brand</option>
                                    <% brands.forEach(b => { %>
                                        <option value="<%= b %>"><%= b %></option>
                                    <% }) %>
                                    <option value="Etc">Etc (Other)</option>
                                </select>
                                <div id="customBrandWrapper" class="hidden absolute top-auto left-0 right-0 z-10 pt-1 mt-11">
                                    <input type="text" name="customBrand" placeholder="Enter custom brand..." class="w-full px-3 py-2.5 rounded-lg bg-white text-black border border-gray-300 focus:outline-none focus:ring-2 focus:ring-yellow-500 shadow-md">
                                </div>
                            </div>
                            <input type="text" name="model" placeholder="Model (e.g. A7 IV)" class="px-3 py-2.5 rounded-lg bg-white text-black border border-gray-300 focus:outline-none focus:ring-2 focus:ring-yellow-500" required>
                            
                            <select name="categoryId" class="px-3 py-2.5 rounded-lg bg-white text-black border border-gray-300 focus:outline-none focus:ring-2 focus:ring-yellow-500" required>
                                <% categories.forEach(cat => { %>
                                    <option value="<%= cat.id %>"><%= cat.name %></option>
                                <% }) %>
                            </select>
                            
                            <input type="number" name="stock" min="1" placeholder="Initial Stock Quantity" class="px-3 py-2.5 rounded-lg bg-white text-black border border-gray-300 focus:outline-none focus:ring-2 focus:ring-yellow-500" required>
                            <input type="number" name="pricePerDay" min="1" placeholder="Price per day" class="px-3 py-2.5 rounded-lg bg-white text-black border border-gray-300 focus:outline-none focus:ring-2 focus:ring-yellow-500" required>
                            <input type="file" name="imageFile" accept=".jpg,.jpeg,.png,.webp,.gif,.svg" class="px-3 py-2.5 rounded-lg bg-white text-black border border-gray-300 focus:outline-none focus:ring-2 focus:ring-yellow-500">
                            <input type="text" name="imageUrl" placeholder="Or paste image URL (optional)" class="px-3 py-2.5 rounded-lg bg-white text-black border border-gray-300 md:col-span-2 focus:outline-none focus:ring-2 focus:ring-yellow-500">
                            <button type="submit" class="md:col-span-2 px-4 py-2.5 rounded-lg bg-brand-yellow text-black font-bold hover:opacity-90 transition">Add Camera</button>
                        </form>
                        <p class="text-xs text-gray-300 mt-2">Visible only to admin. Click the header above to hide/show this panel.</p>
                    </div>
                </section>
            <% } %>

            <!-- Search Bar -->
            <form action="/browse" method="GET" class="flex w-full">
                <% if (selectedType) { %>
                    <input type="hidden" name="type" value="<%= selectedType %>">
                <% } %>
                <input type="text" name="search" value="<%= searchQuery %>" placeholder="Search by brand or model..."
                    class="w-full h-14 bg-[#D9D9D9] text-black px-6 rounded-l-full focus:outline-none focus:ring-2 focus:ring-brand-yellow">
                <button type="submit"
                    class="bg-brand-yellow w-20 h-14 rounded-r-full flex items-center justify-center hover:opacity-90 transition cursor-pointer">
                    <svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                    </svg>
                </button>
            </form>

            <!-- Cards Grid (3 columns like Figma) -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% cameras.forEach(camera=> { %>
                    <div
                        class="camera-card bg-card-dark rounded-xl overflow-hidden shadow-lg flex flex-col border border-gray-800 hover:border-brand-yellow/50 transition duration-300">
                        <!-- Image placeholder -->
                        <div class="h-44 w-full bg-[#111] relative group">
                            <img src="<%= camera.image %>" alt="<%= camera.model %>"
                                class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition">
                            <div
                                class="absolute top-3 right-3 bg-black/80 text-white px-3 py-1 rounded border border-gray-700 text-xs font-bold">
                                Stock: <%= camera.stock %>
                            </div>
                        </div>

                        <!-- Content -->
                        <div class="p-5 flex-1 flex flex-col">
                            <div class="flex justify-between items-start mb-4">
                                <div>
                                    <div class="flex items-center gap-2">
                                        <h3 class="text-xl font-bold text-white tracking-wide">
                                            <%= camera.model %>
                                        </h3>
                                        <button type="button" onclick="showAvailability('<%= camera.id %>')" title="Check Booked Dates" class="text-white hover:text-gray-300 transition" id="availability-btn-<%= camera.id %>">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                            </svg>
                                        </button>
                                    </div>
                                    <p class="text-sm text-gray-400 capitalize">
                                        <%= camera.brand %>
                                    </p>
                                </div>
                                <span class="text-lg font-bold text-brand-yellow">
                                    <%= camera.pricePerDay %> ฿<span
                                            class="text-xs text-gray-500 block text-right font-normal">/day</span>
                                </span>
                            </div>

                            <div class="flex-1"></div>

                            <!-- Booking Form inside Card -->
                            <form action="/book" method="POST" class="space-y-3 mt-4">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <input type="hidden" name="cameraId" value="<%= camera.id %>">

                                <div class="grid grid-cols-2 gap-2">
                                    <div>
                                        <label
                                            class="block text-xs uppercase tracking-wider text-white mb-1">Start</label>
                                        <input type="text" name="startDate" id="start-<%= camera.id %>" required
                                            placeholder="Click me"
                                            data-price="<%= camera.pricePerDay %>"
                                            oninput="calculatePrice('<%= camera.id %>', '<%= camera.pricePerDay %>')"
                                            onchange="calculatePrice('<%= camera.id %>', '<%= camera.pricePerDay %>')"
                                            class="date-picker w-full text-xs bg-black/40 border border-gray-700 rounded p-2 outline-none focus:border-brand-yellow text-white">
                                    </div>
                                    <div>
                                        <label
                                            class="block text-xs uppercase tracking-wider text-white mb-1">End</label>
                                        <input type="text" name="endDate" id="end-<%= camera.id %>" required
                                            placeholder="Click me"
                                            data-price="<%= camera.pricePerDay %>"
                                            oninput="calculatePrice('<%= camera.id %>', '<%= camera.pricePerDay %>')"
                                            onchange="calculatePrice('<%= camera.id %>', '<%= camera.pricePerDay %>')"
                                            class="date-picker w-full text-xs bg-black/40 border border-gray-700 rounded p-2 outline-none focus:border-brand-yellow text-white">
                                    </div>
                                </div>
                                <p id="status-<%= camera.id %>" class="text-xs text-gray-400">Choose start and end date</p>

                                <div class="flex items-center justify-between pt-3 border-t border-gray-800">
                                    <div class="text-xs font-medium text-gray-400">
                                        Total: <span id="total-<%= camera.id %>"
                                            class="text-base font-bold text-white ml-1">0 ฿</span>
                                        <span class="ml-2 text-gray-500">Days: <span id="days-<%= camera.id %>">-</span></span>
                                    </div>
                                    <button type="submit" id="btn-<%= camera.id %>" disabled
                                        class="bg-gray-700 text-white px-4 py-1.5 rounded font-bold transition opacity-50 cursor-not-allowed text-xs uppercase tracking-wider">
                                        Pick dates first
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                    <% }) %>

                        <% if(cameras.length===0) { %>
                            <div class="col-span-full py-20 text-center text-gray-500 font-medium">
                                ไม่พบกล้องที่คุณค้นหา (No cameras found)
                            </div>
                            <% } %>
            </div>

        </main>
    </div>

</body>

</html>