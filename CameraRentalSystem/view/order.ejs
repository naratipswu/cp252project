<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Summary - Camera Rental</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .bg-brand-brown { background-color: #1a150d; }
        .text-brand-yellow { color: #d69e2e; }
        .bg-brand-yellow { background-color: #d69e2e; }
        .bg-card-dark { background-color: #262119; }
    </style>
</head>

<body class="bg-brand-brown text-white min-h-screen">

    <nav class="flex h-16 w-full sticky top-0 z-50 shadow-md bg-brand-brown">
        <a href="/" class="bg-brand-yellow text-black font-black text-xl flex items-center justify-center px-10 tracking-wider">
            CAMERA TYPE
        </a>
        <div class="flex-1 bg-[#222] border-b border-black"></div>
    </nav>

    <div class="max-w-4xl mx-auto px-6 py-12">
        <h1 class="text-4xl font-black mb-8 tracking-tighter uppercase italic">Order Summary</h1>

        <div class="bg-card-dark rounded-2xl overflow-hidden border border-gray-800 shadow-2xl">
            <div class="md:flex">
                <div class="md:w-1/3 h-64 md:h-auto bg-black">
                    <img src="<%= booking.Camera.ImageURL %>" alt="<%= booking.Camera.ModelName %>" class="w-full h-full object-cover opacity-80">
                </div>
                <div class="md:w-2/3 p-8 flex flex-col justify-between">
                    <div>
                        <div class="flex justify-between items-start mb-6">
                            <div>
                                <h2 class="text-3xl font-black mb-1 uppercase tracking-tighter italic"><%= booking.Camera.ModelName %></h2>
                                <p class="text-sm text-brand-yellow font-black uppercase tracking-widest"><%= booking.Camera.Brand %></p>
                            </div>
                            <div class="text-right">
                                <p class="text-gray-500 text-xs uppercase font-bold tracking-widest mb-1">Order ID</p>
                                <p class="font-mono text-gray-300 text-xs">#<%= booking.id %></p>
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-8 mb-8">
                            <div>
                                <p class="text-gray-500 text-xs uppercase font-bold tracking-widest mb-2">Rental Period</p>
                                <p class="text-lg font-bold"><%= booking.start_date %> <span class="text-gray-600 font-normal">to</span> <%= booking.end_date %></p>
                            </div>
                            <div>
                                <p class="text-gray-500 text-xs uppercase font-bold tracking-widest mb-2">Status</p>
                                <span class="px-3 py-1 bg-yellow-500/10 text-yellow-500 rounded-full text-xs font-black uppercase tracking-widest border border-yellow-500/20">
                                    <%= booking.status %>
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="pt-6 border-t border-gray-800 flex items-center justify-between">
                        <div>
                            <p class="text-gray-500 text-xs uppercase font-bold tracking-widest mb-1">Total Amount</p>
                            <p class="text-4xl font-black text-white"><%= booking.total_price %> ฿</p>
                        </div>
                        <a href="/payment/<%= booking.id %>" class="bg-[#d69e2e] text-black px-10 py-4 rounded-2xl font-black text-[11px] uppercase tracking-[0.3em] hover:bg-[#c08e28] transition-all transform active:scale-95 shadow-2xl shadow-[#d69e2e]/20">
                            Proceed to Payment
                        </a>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="mt-8 flex justify-center">
            <a href="/browse" class="text-gray-500 hover:text-white transition text-sm font-bold uppercase tracking-widest flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                Cancel and Return
            </a>
        </div>
    </div>

</body>

</html>
