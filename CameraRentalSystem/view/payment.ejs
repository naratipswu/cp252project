<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Payment - Camera Rental</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .bg-brand-brown { background-color: #1a150d; }
        .text-brand-yellow { color: #d69e2e; }
        .bg-brand-yellow { background-color: #d69e2e; }
        .bg-card-dark { background-color: #262119; }
    </style>
</head>

<body class="bg-brand-brown text-white min-h-screen">

    <nav class="flex h-16 w-full sticky top-0 z-50 shadow-md bg-brand-brown">
        <a href="/" class="bg-brand-yellow text-black font-black text-xl flex items-center justify-center px-10 tracking-wider">
            CAMERA TYPE
        </a>
        <div class="flex-1 bg-[#222] border-b border-black"></div>
    </nav>

    <div class="max-w-4xl mx-auto px-6 py-12">
        <div class="grid md:grid-cols-2 gap-12">
            
            <!-- Left: Payment Info -->
            <div class="space-y-8">
                <div>
                    <h1 class="text-4xl font-black mb-2 tracking-tighter uppercase italic">Checkout</h1>
                    <p class="text-gray-500 font-bold uppercase tracking-widest text-xs">Complete your rental payment via PromptPay</p>
                </div>

                <div class="bg-card-dark rounded-2xl p-8 border border-gray-800 shadow-2xl relative overflow-hidden">
                    <div class="relative z-10">
                        <p class="text-[10px] text-gray-500 font-bold uppercase tracking-widest mb-4">Scan QR to pay</p>
                        <div class="bg-white p-6 rounded-2xl inline-block mb-6 shadow-xl">
                            <!-- Real PromptPay Logo/Style simulation -->
                            <div class="flex justify-center mb-4"><img src="https://upload.wikimedia.org/wikipedia/commons/c/c5/PromptPay_logo.png" class="h-6"></div>
                            <img src="https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=PROMPTPAY_DATA" class="w-48 h-48">
                        </div>
                        <div class="space-y-1">
                            <p class="text-xs text-gray-400">Merchant: <span class="text-white font-bold">CAMERA RENTAL CO.</span></p>
                            <p class="text-xs text-gray-400">Total Amount: <span class="text-brand-yellow font-black text-lg"><%= booking.total_price %> ฿</span></p>
                        </div>
                    </div>
                    <!-- Background Accent -->
                    <div class="absolute -bottom-10 -right-10 w-40 h-40 bg-brand-yellow/5 rounded-full blur-3xl"></div>
                </div>

                <form action="/payment/process" method="POST">
                    <input type="hidden" name="bookingId" value="<%= booking.id %>">
                    <button type="submit" class="w-full bg-[#d69e2e] text-black py-4.5 py-4 rounded-2xl font-black text-[11px] uppercase tracking-[0.35em] hover:bg-[#c08e28] transition-all transform active:scale-95 shadow-2xl shadow-[#d69e2e]/20">
                        I have paid via PromptPay
                    </button>
                    <p class="text-center text-[10px] text-gray-600 mt-4 uppercase tracking-widest font-bold">Secure payment powered by PromptPay QR</p>
                </form>
            </div>

            <!-- Right: Item Summary -->
            <div class="space-y-6">
                <h2 class="text-sm font-black uppercase tracking-widest text-gray-500 border-b border-gray-800 pb-2">Order Summary</h2>
                <div class="bg-card-dark rounded-2xl p-6 border border-gray-800 flex gap-6 items-center">
                    <div class="h-24 w-24 bg-black rounded-lg overflow-hidden flex-shrink-0">
                        <img src="<%= booking.Camera.ImageURL %>" class="w-full h-full object-cover opacity-80">
                    </div>
                    <div>
                        <h2 class="text-xl font-black uppercase tracking-tighter italic"><%= booking.Camera.ModelName %></h2>
                        <p class="text-[10px] text-brand-yellow font-black uppercase tracking-widest"><%= booking.Camera.Brand %></p>
                        <p class="text-xs text-gray-400 mt-2 font-bold uppercase"><%= booking.total_price %> ฿</p>
                    </div>
                </div>

                <div class="bg-card-dark rounded-2xl p-6 border border-gray-800 space-y-4">
                    <div class="flex justify-between items-center text-xs uppercase font-bold tracking-widest">
                        <span class="text-gray-500">Rental Subtotal</span>
                        <span><%= booking.total_price %> ฿</span>
                    </div>
                    <div class="flex justify-between items-center text-xs uppercase font-bold tracking-widest">
                        <span class="text-gray-500">Insurance Fee</span>
                        <span class="text-green-500">FREE</span>
                    </div>
                    <div class="pt-4 border-t border-gray-800 flex justify-between items-center">
                        <span class="text-sm font-black uppercase tracking-widest text-white">Grand Total</span>
                        <span class="text-2xl font-black text-brand-yellow"><%= booking.total_price %> ฿</span>
                    </div>
                </div>
            </div>

        </div>
    </div>

</body>

</html>
