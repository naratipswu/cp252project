<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Manage Camera Stock</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#f8f9fa] min-h-screen font-sans text-slate-800">
    <nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex items-center gap-3">
                    <div class="bg-slate-900 p-2 rounded-lg">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    </div>
                    <h1 class="text-xl font-bold text-slate-900 tracking-tight">Manage Camera Stock</h1>
                </div>
                <div class="flex items-center gap-4">
                    <a href="/admin" class="text-indigo-600 hover:text-indigo-800 text-sm font-semibold transition">Back to Dashboard</a>
                    <span class="w-px h-4 bg-gray-300"></span>
                    <a href="/browse" class="text-slate-600 hover:text-slate-900 text-sm font-medium transition">Storefront</a>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <section>
            <div class="mb-8">
                <h2 class="text-2xl font-bold text-slate-900 tracking-tight">Equipment Inventory</h2>
                <p class="text-sm text-slate-500 mt-1">Review your stock, change statuses, or delete entries.</p>
            </div>
            
            <% if (error) { %>
                <div class="mb-6 p-4 rounded-xl border border-red-200 bg-red-50 text-red-700 font-medium text-sm shadow-sm">
                    <%= error %>
                </div>
            <% } %>

            <div class="bg-white shadow-[0_2px_8px_-3px_rgba(0,0,0,0.05)] rounded-2xl overflow-hidden border border-gray-100">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-100">
                        <thead class="bg-slate-50/50">
                            <tr>
                                <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Image</th>
                                <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Brand/Model</th>
                                <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Serial Number</th>
                                <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Rate/Day</th>
                                <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Category</th>
                                <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Status</th>
                                <th class="px-6 py-4 text-right text-xs font-semibold text-slate-500 uppercase tracking-wider">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-50">
                            <% cameras.forEach(cam => { %>
                                <tr class="hover:bg-slate-50/50 transition-colors">
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="w-12 h-12 rounded-lg bg-gray-100 border border-gray-200 overflow-hidden">
                                            <img src="<%= cam.ImageURL %>" alt="cam" class="w-full h-full object-cover">
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="font-bold text-slate-900"><%= cam.ModelName %></div>
                                        <div class="text-slate-500 text-xs font-medium mt-0.5"><%= cam.Brand %></div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500 font-mono text-xs">
                                        <%= cam.SerialNumber %>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-emerald-600">
                                        <%= Number(cam.DailyRate).toLocaleString() %> ฿
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                                        <span class="bg-slate-100 text-slate-600 px-2.5 py-1 rounded-md text-xs font-semibold"><%= cam.Category ? cam.Category.CategoryName : 'General' %></span>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <form action="/admin/cameras/<%= cam.EquipmentID %>/status" method="POST">
                                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                            <select name="status" onchange="this.form.submit()" class="<%= cam.Status === 'available' ? 'text-emerald-700 bg-emerald-50 border-emerald-200' : 'text-amber-700 bg-amber-50 border-amber-200' %> border rounded-md text-xs px-3 py-1.5 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 font-bold cursor-pointer transition-colors">
                                                <option value="available" <%= cam.Status === 'available' ? 'selected' : '' %>>Available</option>
                                                <option value="maintenance" <%= cam.Status === 'maintenance' ? 'selected' : '' %>>Maintenance</option>
                                            </select>
                                        </form>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-right font-medium">
                                        <form action="/admin/cameras/<%= cam.EquipmentID %>/delete" method="POST" class="inline" onsubmit="return confirm('Are you sure you want to delete this camera? This could fail if there are existing bookings for it.');">
                                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                            <button type="submit" class="text-red-600 hover:text-red-700 bg-red-50 hover:bg-red-100 px-3 py-1.5 rounded-md text-xs font-semibold transition-colors">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                            <% if(cameras.length === 0) { %>
                                <tr><td colspan="7" class="px-6 py-12 text-center text-slate-400 font-medium bg-slate-50/30">No cameras found. Add them from the Browse page.</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    </main>
</body>
</html>
