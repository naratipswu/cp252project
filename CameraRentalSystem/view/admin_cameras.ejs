<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Equipment Inventory | Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-[#f8fafc] min-h-screen text-slate-800">
    <!-- Navbar -->
    <nav class="bg-white border-b border-slate-200 sticky top-0 z-30 shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex items-center gap-3">
                    <div class="bg-indigo-600 p-2 rounded-lg shadow-lg shadow-indigo-100">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    </div>
                    <div>
                        <h1 class="text-xl font-extrabold text-slate-900 tracking-tight">Camera Inventory</h1>
                        <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest leading-none mt-0.5">Asset Management</p>
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <a href="/admin" class="px-4 py-2 text-sm font-bold border border-slate-200 text-slate-600 hover:bg-slate-900 hover:text-white rounded-lg transition-all shadow-sm">Back to Dashboard</a>
                    <a href="/browse" class="px-4 py-2 text-sm font-bold bg-indigo-600 text-white hover:bg-indigo-700 rounded-lg transition-all shadow-md shadow-indigo-100">Storefront</a>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 animate-[fadeIn_0.5s_ease-out]">
        
        <header class="mb-8 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <div>
                <h2 class="text-2xl font-black text-slate-900">Equipment List</h2>
                <p class="text-sm font-medium text-slate-500">Manage your rental assets and physical inventory status</p>
            </div>
            <div class="flex items-center gap-2 bg-white p-1.5 rounded-xl border border-slate-200">
                <div class="px-4 py-1.5 bg-slate-50 rounded-lg text-xs font-bold text-slate-500 border border-slate-100">
                    Total: <span class="text-slate-900"><%= cameras.length %></span>
                </div>
                <div class="px-4 py-1.5 bg-emerald-50 rounded-lg text-xs font-bold text-emerald-600 border border-emerald-100">
                    Available: <span class="text-emerald-700"><%= cameras.filter(c => c.Status === 'available').length %></span>
                </div>
            </div>
        </header>

        <% if (error) { %>
            <div class="mb-6 flex items-center gap-3 p-4 rounded-xl border border-red-200 bg-red-50 text-red-700 shadow-sm">
                <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <span class="font-bold text-sm"><%= error %></span>
            </div>
        <% } %>

        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="bg-slate-50 border-b border-slate-100">
                        <tr>
                            <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Image</th>
                            <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Brand & Model</th>
                            <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Serial</th>
                            <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Rate / Day</th>
                            <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Category</th>
                            <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest text-center">Status</th>
                            <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-50">
                        <% cameras.forEach(cam => { %>
                            <tr class="hover:bg-slate-50/50 transition-colors group">
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="relative w-14 h-14 rounded-xl overflow-hidden border border-slate-200 bg-slate-100 shadow-sm group-hover:scale-105 transition-transform">
                                        <img src="<%= cam.ImageURL %>" alt="cam" class="w-full h-full object-cover">
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm font-black text-slate-900"><%= cam.ModelName %></div>
                                    <div class="text-[10px] font-bold text-indigo-500 uppercase tracking-wider"><%= cam.Brand %></div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="text-xs font-mono font-bold text-slate-400 bg-slate-50 px-2 py-1 rounded border border-slate-100"><%= cam.SerialNumber %></span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm font-black text-emerald-600 tracking-tight"><%= Number(cam.DailyRate).toLocaleString() %> <span class="text-[10px] font-bold text-slate-300">฿</span></div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="text-[10px] font-black px-2 py-1 bg-slate-100 text-slate-600 rounded-md uppercase tracking-wider border border-slate-200">
                                        <%= cam.Category ? cam.Category.CategoryName : 'General' %>
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-center">
                                    <form action="/admin/cameras/<%= cam.EquipmentID %>/status" method="POST" class="inline-block">
                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                        <select name="status" onchange="this.form.submit()" class="text-[10px] font-black uppercase tracking-widest px-3 py-1.5 rounded-full border-none ring-1 ring-inset cursor-pointer outline-none focus:ring-indigo-500 transition-all
                                            <%= cam.Status === 'available' 
                                                ? 'bg-emerald-50 text-emerald-700 ring-emerald-600/20 hover:bg-emerald-100' 
                                                : 'bg-rose-50 text-rose-700 ring-rose-600/20 hover:bg-rose-100' %>">
                                            <option value="available" <%= cam.Status === 'available' ? 'selected' : '' %>>Available</option>
                                            <option value="maintenance" <%= cam.Status === 'maintenance' ? 'selected' : '' %>>Maintenance</option>
                                        </select>
                                    </form>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-right pr-6">
                                    <form action="/admin/cameras/<%= cam.EquipmentID %>/delete" method="POST" class="inline" onsubmit="return confirm('WARNING: Permanently delete this item? This cannot be undone.');">
                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                        <button type="submit" class="p-2 text-slate-300 hover:text-rose-600 hover:bg-rose-50 rounded-lg transition-all opacity-0 group-hover:opacity-100 focus:opacity-100">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                        <% if(cameras.length === 0) { %>
                            <tr>
                                <td colspan="7" class="px-6 py-20 text-center">
                                    <div class="flex flex-col items-center">
                                        <div class="bg-slate-50 p-6 rounded-full mb-4">
                                            <svg class="w-10 h-10 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 1 0 01-2-2v-5m16 0h-3.586a1 1 0 00-.707.293l-1.414 1.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-1.414-1.414A1 1 0 006.586 13H4"></path></svg>
                                        </div>
                                        <h3 class="text-lg font-bold text-slate-900 mb-1">Inventory is empty</h3>
                                        <p class="text-sm text-slate-400 font-medium max-w-xs">No equipment has been added to the database yet.</p>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <style>
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</body>
</html>
