<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>How It Works - Camera Rental</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@400;700;900&display=swap"
        rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        .font-serif-elegant {
            font-family: 'Playfair Display', serif;
        }

        .bg-brand-brown {
            background-color: #1a150d;
        }

        .text-brand-yellow {
            color: #d69e2e;
        }

        .bg-brand-yellow {
            background-color: #d69e2e;
        }

        .border-brand-yellow {
            border-color: #d69e2e;
        }
        
        .bg-pattern {
            background-image: radial-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px);
            background-size: 40px 40px;
        }
    </style>
</head>

<body class="bg-brand-brown text-white min-h-screen relative flex flex-col bg-pattern">

    <!-- Navbar -->
    <nav class="flex h-16 w-full shrink-0 border-b border-white/10 relative z-10 bg-brand-brown">
        <!-- Logo Area -->
        <a href="/" class="bg-brand-yellow text-black font-black text-lg md:text-xl flex items-center justify-center px-6 md:px-10 tracking-wider hover:bg-yellow-500 transition">
            CAMERA TYPE
        </a>

        <!-- Navigation Links -->
        <div class="flex-1 bg-[#222] flex items-center justify-start px-8 gap-8 hidden md:flex">
            <a href="/browse?type=digital" class="text-white font-bold tracking-wider hover:text-brand-yellow transition">DIGITAL</a>
            <a href="/browse?type=film" class="text-white font-bold tracking-wider hover:text-brand-yellow transition">FILM</a>
            <a href="#" class="text-white font-bold tracking-wider hover:text-brand-yellow transition">PHOTO</a>
            <a href="/process" class="text-brand-yellow font-bold tracking-wider transition">PROCESS</a>
            <a href="/contact" class="text-white font-bold tracking-wider hover:text-brand-yellow transition">CONTACT</a>
        </div>

        <!-- Icons Area -->
        <div class="bg-white text-black flex items-center justify-center px-6 gap-6 ml-auto md:ml-0">
            <a href="<%= user ? '/profile' : '/signin' %>" class="hover:text-gray-600 transition" title="<%= user ? 'Profile' : 'Sign in' %>">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                </svg>
            </a>
            <a href="/cart" class="hover:text-gray-600 transition" title="Cart">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z">
                    </path>
                </svg>
            </a>
        </div>
    </nav>

    <!-- Content -->
    <main class="flex-1 flex flex-col items-center justify-center py-20 px-4 md:px-8 max-w-6xl mx-auto w-full relative z-10">
        
        <div class="text-center mb-16 md:mb-24">
            <h1 class="font-serif-elegant text-5xl md:text-7xl mb-4 text-white drop-shadow-lg tracking-wide">ขั้นตอนการเช่า</h1>
            <div class="w-16 h-1 bg-brand-yellow mx-auto my-6"></div>
            <p class="font-serif-elegant text-lg md:text-2xl italic text-gray-400">เริ่มต้นเส้นทางการเก็บบันทึกความทรงจำของคุณกับเรา</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-16 w-full mt-4">
            <!-- Step 1 -->
            <div class="flex flex-col items-center text-center group">
                <!-- Image Placeholder -->
                <div class="w-full aspect-[4/3] bg-gray-800 rounded-lg overflow-hidden mb-8 border border-white/10 group-hover:border-brand-yellow/50 transition duration-500 relative flex items-center justify-center">
                    <span class="text-gray-500 text-sm tracking-widest uppercase">Image Space</span>
                    <!-- You can replace the src below with your actual image path -->
                    <!-- <img src="/uploads/images/step1.jpg" alt="Discover" class="w-full h-full object-cover"> -->
                </div>

                <div class="w-16 h-16 rounded-full border border-gray-600 flex items-center justify-center mb-6 group-hover:border-brand-yellow group-hover:bg-brand-yellow/10 transition duration-500 relative">
                    <span class="font-serif-elegant text-2xl text-gray-500 group-hover:text-brand-yellow transition">01</span>
                    <div class="hidden md:block absolute top-1/2 left-full w-full h-px bg-gray-600 w-[calc(100%+2rem)] -translate-y-1/2 -z-10 group-hover:bg-brand-yellow transition duration-500"></div>
                </div>
                <h3 class="text-xl font-bold tracking-widest mb-3 uppercase">ค้นหาและเลือกสรร</h3>
                <p class="text-gray-400 leading-relaxed max-w-xs text-sm">
                    เลือกชมกล้องสุดคลาสสิกที่คัดสรรมาอย่างดี เลือกรุ่นที่เหมาะกับสไตล์ของคุณ และระบุวันที่ต้องการเช่า
                </p>
            </div>

            <!-- Step 2 -->
            <div class="flex flex-col items-center text-center group md:mt-12">
                <!-- Image Placeholder -->
                <div class="w-full aspect-[4/3] bg-gray-800 rounded-lg overflow-hidden mb-8 border border-white/10 group-hover:border-brand-yellow/50 transition duration-500 relative flex items-center justify-center">
                    <span class="text-gray-500 text-sm tracking-widest uppercase">Image Space</span>
                    <!-- You can replace the src below with your actual image path -->
                    <!-- <img src="/uploads/images/step2.jpg" alt="Confirm & Pay" class="w-full h-full object-cover"> -->
                </div>

                <div class="w-16 h-16 rounded-full border border-gray-600 flex items-center justify-center mb-6 group-hover:border-brand-yellow group-hover:bg-brand-yellow/10 transition duration-500 relative">
                    <span class="font-serif-elegant text-2xl text-gray-500 group-hover:text-brand-yellow transition">02</span>
                    <div class="hidden md:block absolute top-1/2 left-full w-full h-px bg-gray-600 w-[calc(100%+2rem)] -translate-y-1/2 -z-10 group-hover:bg-brand-yellow transition duration-500"></div>
                </div>
                <h3 class="text-xl font-bold tracking-widest mb-3 uppercase">ยืนยันและชำระเงิน</h3>
                <p class="text-gray-400 leading-relaxed max-w-xs text-sm">
                    ตรวจสอบรายละเอียดการจองของคุณและแนบสลิปชำระเงิน เมื่อผ่านการยืนยัน อุปกรณ์ของคุณจะถูกเตรียมให้พร้อม
                </p>
            </div>

            <!-- Step 3 -->
            <div class="flex flex-col items-center text-center group md:mt-24">
                <!-- Image Placeholder -->
                <div class="w-full aspect-[4/3] bg-gray-800 rounded-lg overflow-hidden mb-8 border border-white/10 group-hover:border-brand-yellow/50 transition duration-500 relative flex items-center justify-center">
                    <span class="text-gray-500 text-sm tracking-widest uppercase">Image Space</span>
                    <!-- You can replace the src below with your actual image path -->
                    <!-- <img src="/uploads/images/step3.jpg" alt="Capture" class="w-full h-full object-cover"> -->
                </div>

                <div class="w-16 h-16 rounded-full border border-gray-600 flex items-center justify-center mb-6 group-hover:border-brand-yellow group-hover:bg-brand-yellow/10 transition duration-500">
                    <span class="font-serif-elegant text-2xl text-gray-500 group-hover:text-brand-yellow transition">03</span>
                </div>
                <h3 class="text-xl font-bold tracking-widest mb-3 uppercase">รับของและสนุกไปกับการถ่ายภาพ</h3>
                <p class="text-gray-400 leading-relaxed max-w-xs text-sm">
                    รับอุปกรณ์ของคุณและออกเดินทางไปเก็บภาพความประทับใจ เมื่อใช้งานเสร็จสิ้น สามารถนำมาคืนได้อย่างง่ายดาย
                </p>
            </div>
        </div>

        <div class="mt-32 text-center h-[200px]">
            <a href="/browse" class="inline-block border border-brand-yellow text-brand-yellow px-10 py-4 font-bold tracking-widest hover:bg-brand-yellow hover:text-black transition duration-300">
                เริ่มเข้าชมสินค้า
            </a>
        </div>
    </main>

</body>
</html>
