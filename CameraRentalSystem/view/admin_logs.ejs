<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>System Logs</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#f8f9fa] min-h-screen font-sans text-slate-800">
    <nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex items-center gap-3">
                    <div class="bg-slate-900 p-2 rounded-lg">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <h1 class="text-xl font-bold text-slate-900 tracking-tight">System Logs</h1>
                </div>
                <div class="flex items-center gap-4">
                    <a href="/admin" class="text-indigo-600 hover:text-indigo-800 text-sm font-semibold transition">Back to Dashboard</a>
                    <span class="w-px h-4 bg-gray-300"></span>
                    <span class="text-slate-500 text-sm">Logged in as <%= user.username %></span>
                    <form action="/logout" method="POST" class="inline m-0 p-0 ml-2">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button type="submit" class="bg-slate-900 hover:bg-slate-800 text-white px-4 py-1.5 rounded-lg text-sm font-semibold transition shadow-sm">Logout</button>
                    </form>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <div class="mb-8">
            <h2 class="text-2xl font-bold text-slate-900 tracking-tight">Execution Logs & Errors</h2>
            <p class="text-sm text-slate-500 mt-1">Review system activity and troubleshoot issues in real-time.</p>
        </div>

        <div class="bg-white shadow-[0_2px_8px_-3px_rgba(0,0,0,0.05)] rounded-2xl overflow-hidden border border-gray-100">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-100">
                    <thead class="bg-slate-50/50">
                        <tr>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Log ID</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Process Source</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Status</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Message Details</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Time (Local)</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-50">
                        <% logs.forEach(log => { %>
                            <tr class="hover:bg-slate-50/50 transition-colors <%= log.status === 'failed' ? 'bg-red-50/30 hover:bg-red-50/50' : '' %>">
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-slate-900">#<%= log.id %></td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-700 font-semibold"><%= log.source %></td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm">
                                    <% if(log.status === 'failed') { %>
                                        <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-bold bg-red-100 text-red-700 border border-red-200">
                                            Failed
                                        </span>
                                    <% } else { %>
                                        <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-bold bg-emerald-100 text-emerald-700 border border-emerald-200">
                                            Success
                                        </span>
                                    <% } %>
                                </td>
                                <td class="px-6 py-4 text-sm text-slate-600 break-words max-w-xl">
                                    <%= log.message || '-' %>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500 font-mono text-xs">
                                    <%= new Date(log.syncedAt).toLocaleString() %>
                                </td>
                            </tr>
                        <% }) %>
                        <% if(logs.length === 0) { %>
                            <tr><td colspan="5" class="px-6 py-12 text-center text-slate-400 font-medium bg-slate-50/30">No logs generated yet.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</body>
</html>
